<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ metadata.target_repo }} — Pre-Upgrade Risk Report</title>
{% if not offline %}
{% for a in cdn_assets %}{% if a.kind == 'css' %}<link rel="stylesheet" href="{{ a.href }}">{% endif %}{% endfor %}
{% for a in cdn_assets %}{% if a.kind == 'js' %}<script src="{{ a.src }}" defer></script>{% endif %}{% endfor %}
{% endif %}
<style>
:root {
  --primary:#1F4E79; --accent:#2E75B6; --danger:#C53030; --warning:#D69E2E;
  --success:#38A169; --surface:#F8FAFC; --card:#FFFFFF; --text:#1A202C; --muted:#718096;
}
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:Inter,system-ui,-apple-system,Segoe UI,Roboto,sans-serif;background:var(--surface);color:var(--text);line-height:1.5}
.site-header{position:sticky;top:0;z-index:100;background:var(--card);border-bottom:1px solid #e2e8f0;padding:1rem 1.5rem}
.header-inner{max-width:1280px;margin:0 auto;display:flex;justify-content:space-between;align-items:center;gap:1rem;flex-wrap:wrap}
.header-title h1{font-size:1.25rem;color:var(--primary)}
.header-meta{font-size:.85rem;color:var(--muted)}
.header-badge{text-align:right;padding:.5rem 1rem;border-radius:8px;color:#fff}
.header-badge.rec-BLOCK{background:var(--danger)}
.header-badge.rec-REVIEW{background:var(--warning);color:var(--text)}
.header-badge.rec-PROCEED{background:var(--success)}
.badge-rec{display:block;font-weight:700;font-size:1rem}
.badge-score{font-size:.9rem;opacity:.95}
.tab-nav{position:sticky;top:72px;z-index:90;background:var(--card);border-bottom:1px solid #e2e8f0;padding:.5rem 1.5rem;display:flex;gap:.35rem;flex-wrap:wrap;max-width:1280px;margin:0 auto}
.tab-btn{border:1px solid #cbd5e0;background:#fff;color:var(--text);padding:.45rem .9rem;border-radius:6px;cursor:pointer;font-size:.85rem}
.tab-btn[aria-selected="true"],.tab-btn.active{background:var(--primary);color:#fff;border-color:var(--primary)}
.tab-btn:focus-visible{outline:2px solid var(--accent);outline-offset:2px}
main{max-width:1280px;margin:0 auto;padding:1.25rem 1.5rem 3rem}
.tab-panel.hidden{display:none!important}
.card{background:var(--card);border-radius:10px;padding:1.25rem;box-shadow:0 1px 3px rgba(0,0,0,.08);margin-bottom:1rem}
.banner{text-align:center;padding:1.5rem;border-radius:10px;color:#fff;margin-bottom:1rem}
.banner.rec-BLOCK{background:var(--danger)}
.banner.rec-REVIEW{background:var(--warning);color:var(--text)}
.banner.rec-PROCEED{background:var(--success)}
.banner-rec{font-size:1.5rem;font-weight:700}
.stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1rem}
.stat-card{background:var(--card);border-radius:10px;padding:1rem;text-align:center;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.stat-num{display:block;font-size:2rem;font-weight:700;color:var(--primary)}
.stat-label{font-size:.8rem;color:var(--muted)}
.prose{font-size:1rem;color:#2d3748}
.toolbar{display:flex;flex-wrap:wrap;gap:1rem;align-items:center;margin-bottom:1rem}
.search-input{padding:.4rem .6rem;border:1px solid #cbd5e0;border-radius:6px;min-width:200px}
.data-table{width:100%;border-collapse:collapse;font-size:.85rem}
.data-table th,.data-table td{padding:.5rem .6rem;border-bottom:1px solid #e2e8f0;text-align:left}
.data-table th{cursor:pointer;background:#edf2f7}
.mono{font-family:Consolas,Monaco,monospace;font-size:.8rem}
.tag{display:inline-block;padding:2px 8px;border-radius:4px;font-size:.72rem;font-weight:600;color:#fff}
.tag-BLOCK{background:var(--danger)}
.tag-REVIEW{background:var(--warning);color:var(--text)}
.tag-PROCEED{background:var(--success)}
.tag-high{background:var(--accent)}
.tag-muted{background:#a0aec0}
.kev-yes{color:var(--danger);font-weight:700}
.detail-row.hidden{display:none}
.detail-panel{padding:1rem;background:#f7fafc;border-radius:8px}
.code-snippet{font-size:.75rem;overflow:auto}
.score-row{display:flex;align-items:center;gap:.5rem;margin:.35rem 0}
.score-row span:first-child{width:100px;font-size:.8rem}
.bar{flex:1;height:18px;background:#e2e8f0;border-radius:4px;overflow:hidden}
.fill{height:100%}
.fill-sev{background:var(--danger)}.fill-exp{background:#dd6b20}.fill-reach{background:var(--warning)}.fill-blast{background:#805ad5}
.diff-grid{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.timeline{padding-left:1.25rem}
.step-card{border-left:4px solid var(--accent);padding:.75rem 1rem;margin:.5rem 0;background:#f7fafc}
.step-num{font-weight:700;color:var(--primary);font-size:.75rem}
/* ── Neo4j Browser-faithful graph UI ─────────────────────────── */
.neo4j-ui{display:grid;grid-template-columns:210px 1fr 195px;height:620px;background:#1b2a38;border-radius:10px;overflow:hidden;border:1px solid #2d3f50;font-family:Inter,system-ui,sans-serif}
.neo-schema,.neo-results{background:#1b2a38;overflow-y:auto;padding:.75rem;scrollbar-width:thin;scrollbar-color:#2d3f50 transparent}
.neo-schema{border-right:1px solid #2d3f50}
.neo-results{border-left:1px solid #2d3f50}
.neo-graph-col{display:flex;flex-direction:column;min-width:0;background:#1e2b3a}
.neo-query-bar{display:flex;align-items:center;gap:.5rem;background:#0f1d29;padding:.4rem .75rem;border-bottom:1px solid #2d3f50;flex-shrink:0;min-width:0}
.neo-prompt{color:#57a64a;font-size:.72rem;font-family:Consolas,monospace;white-space:nowrap;flex-shrink:0}
.neo-query-txt{flex:1;color:#c5d5e4;font-size:.74rem;font-family:Consolas,monospace;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;min-width:0}
.neo-q-btns{display:flex;gap:.2rem;flex-shrink:0}
.neo-q-btn{background:transparent;border:none;color:#71869d;cursor:pointer;padding:.15rem .3rem;border-radius:3px;font-size:.85rem;line-height:1}
.neo-q-btn:hover{color:#c5d5e4;background:#2d3f50}
.neo-view-tabs{display:flex;background:#0f1d29;border-bottom:1px solid #2d3f50;flex-shrink:0;padding:0 .5rem}
.neo-vtab{background:transparent;border:none;border-bottom:2px solid transparent;color:#71869d;padding:.3rem .7rem;cursor:pointer;font-size:.74rem;transition:color .15s}
.neo-vtab.active{color:#00b0d4;border-bottom-color:#00b0d4}
.neo-canvas-wrap{flex:1;position:relative;min-height:0;background:#1e2b3a}
.neo-canvas-wrap canvas{background:transparent!important}
.neo-bottom{display:flex;align-items:center;justify-content:space-between;background:#0f1d29;padding:.28rem .75rem;border-top:1px solid #2d3f50;flex-shrink:0}
.neo-stat{color:#71869d;font-size:.68rem;font-family:Consolas,monospace}
.neo-zoom{display:flex;gap:.2rem}
.neo-z-btn{background:#243040;border:none;color:#a0b4c5;width:22px;height:22px;border-radius:3px;cursor:pointer;font-size:.8rem;display:flex;align-items:center;justify-content:center;transition:background .15s}
.neo-z-btn:hover{background:#3d5266;color:#e2eaf0}
.neo-phdr{font-size:.72rem;font-weight:700;color:#c5d5e4;padding-bottom:.45rem;border-bottom:1px solid #2d3f50;margin-bottom:.6rem;display:flex;justify-content:space-between;align-items:center}
.neo-ptitle{font-size:.62rem;color:#71869d;text-transform:uppercase;letter-spacing:.07em;font-weight:600;margin:.55rem 0 .3rem}
.neo-pills{display:flex;flex-wrap:wrap;gap:.25rem;margin-bottom:.5rem}
.neo-npill{display:inline-flex;align-items:center;gap:3px;padding:2px 7px 2px 5px;border-radius:10px;font-size:.66rem;font-weight:600;color:#fff;cursor:pointer;transition:opacity .15s}
.neo-npill:hover{opacity:.8}
.neo-ndot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.neo-rpill{display:inline-block;padding:1px 6px;background:#243040;border-radius:3px;font-size:.63rem;color:#a0b4c5;cursor:pointer;transition:background .15s}
.neo-rpill:hover{background:#2d3f50;color:#e2eaf0}
.neo-props{display:flex;flex-wrap:wrap;gap:.2rem}
.neo-pk{font-size:.6rem;color:#71869d;background:#243040;padding:1px 5px;border-radius:3px}
.neo-detail{background:#0f1d29;border-radius:5px;padding:.6rem;margin-top:.4rem;min-height:55px}
.neo-dl{font-size:.6rem;text-transform:uppercase;font-weight:700;letter-spacing:.08em;margin-bottom:3px}
.neo-dn{font-weight:600;font-size:.82rem;word-break:break-all;margin-bottom:5px}
.neo-dr{display:flex;gap:.3rem;padding:2px 0;border-bottom:1px solid #1e2b3a}
.neo-dk{color:#71869d;min-width:75px;flex-shrink:0;font-size:.7rem}
.neo-dv{color:#c5d5e4;font-size:.7rem}
.neo-sev-badge{display:inline-block;padding:1px 6px;border-radius:8px;font-size:.62rem;font-weight:700;color:#fff;margin-right:3px}
.site-footer{text-align:center;padding:2rem;color:var(--muted);font-size:.8rem}
.btn{padding:.45rem .9rem;border-radius:6px;border:none;cursor:pointer;font-size:.85rem}
.btn-secondary{background:#edf2f7;color:var(--text)}
.empty-state{padding:2rem;text-align:center;color:var(--muted)}
.conflict-diagram{display:flex;align-items:center;justify-content:center;gap:1rem;margin-top:1rem;padding:1rem;background:#fff5f5;border-radius:8px}
@media(max-width:768px){.stat-grid{grid-template-columns:1fr 1fr}.diff-grid,.graph-layout{grid-template-columns:1fr}.tab-nav{top:auto;position:relative}}
@media print{
  .tab-nav,.toolbar,.btn,.btn-expand{display:none!important}
  .tab-panel,.tab-panel.hidden{display:block!important;page-break-after:always}
  body{background:#fff}
}
</style>
</head>
<body>
{% include 'partials/_header.html.j2' %}
{% include 'partials/_tab_nav.html.j2' %}
<main>
{% include 'tabs/_executive.html.j2' %}
{% include 'tabs/_technical.html.j2' %}
{% include 'tabs/_patches.html.j2' %}
{% include 'tabs/_upgrade.html.j2' %}
{% include 'tabs/_graph.html.j2' %}
</main>
{% include 'partials/_footer.html.j2' %}
<script>
const REPORT_CVES = {{ cves_json|safe }};
const GRAPH_DATA = {{ graph_json|safe }};
const CHART_SCORES = {{ chart_json|safe }};
</script>
<script>
(function(){
  const tabs = document.querySelectorAll('.tab-btn');
  const panels = document.querySelectorAll('.tab-panel');
  function showTab(id){
    tabs.forEach(t=>{const on=t.dataset.tab===id; t.classList.toggle('active',on); t.setAttribute('aria-selected',on?'true':'false');});
    panels.forEach(p=>{const on=p.id==='tab-'+id; p.classList.toggle('hidden',!on); p.hidden=!on;});
    if(id==='graph' && window.initGraph) window.initGraph();
  }
  tabs.forEach((t,i)=>{
    t.addEventListener('click',()=>showTab(t.dataset.tab));
    t.addEventListener('keydown',e=>{
      if(e.key==='ArrowRight'||e.key==='ArrowLeft'){
        e.preventDefault();
        const n=e.key==='ArrowRight'?(i+1)%tabs.length:(i-1+tabs.length)%tabs.length;
        tabs[n].focus(); showTab(tabs[n].dataset.tab);
      }
    });
  });

  const table=document.getElementById('cve-table');
  if(table){
    let sortKey='cvss',sortAsc=false;
    table.querySelectorAll('th[data-sort]').forEach(th=>{
      th.addEventListener('click',()=>{
        const k=th.dataset.sort;
        if(sortKey===k) sortAsc=!sortAsc; else{sortKey=k;sortAsc=false;}
        const tbody=table.querySelector('tbody');
        const pairs=[];
        tbody.querySelectorAll('tr.cve-row').forEach(row=>{
          const detail=document.getElementById(row.querySelector('.btn-expand').dataset.target);
          pairs.push({row,detail});
        });
        pairs.sort((a,b)=>{
          const av=a.row.dataset[sortKey==='cve'?'cve':sortKey==='rec'?'rec':sortKey==='reach'?'reachable':sortKey]||0;
          const bv=b.row.dataset[sortKey==='cve'?'cve':sortKey==='rec'?'rec':sortKey==='reach'?'reachable':sortKey]||0;
          if(sortKey==='cvss'||sortKey==='epss') return (parseFloat(av)-parseFloat(bv))*(sortAsc?1:-1);
          return String(av).localeCompare(String(bv))*(sortAsc?1:-1);
        });
        pairs.forEach(p=>{tbody.appendChild(p.row); if(p.detail) tbody.appendChild(p.detail);});
      });
    });
    document.querySelectorAll('.btn-expand').forEach(btn=>{
      btn.addEventListener('click',()=>{
        const tr=document.getElementById(btn.dataset.target);
        const open=tr.classList.toggle('hidden');
        btn.setAttribute('aria-expanded',open?'false':'true');
        btn.textContent=open?'▶':'▼';
        tr.hidden=open;
      });
    });
    function applyFilters(){
      const rec=document.getElementById('filter-rec').value;
      const reach=document.getElementById('filter-reachable').checked;
      const q=(document.getElementById('filter-search').value||'').toLowerCase();
      table.querySelectorAll('tr.cve-row').forEach(row=>{
        const ok=(rec==='all'||row.dataset.rec===rec)&&(!reach||row.dataset.reachable==='1')&&(!q||row.textContent.toLowerCase().includes(q));
        row.style.display=ok?'':'none';
        const d=document.getElementById(row.querySelector('.btn-expand').dataset.target);
        if(d&&!ok) d.style.display='none';
      });
    }
    ['filter-rec','filter-reachable','filter-search'].forEach(id=>{
      const el=document.getElementById(id);
      if(el) el.addEventListener(el.type==='checkbox'?'change':'input',applyFilters);
    });
  }

  const sel=document.getElementById('patch-cve-select');
  if(sel){
    sel.addEventListener('change',()=>{
      document.querySelectorAll('.patch-panel').forEach((p,i)=>{
        const on=String(i)===sel.value;
        p.classList.toggle('hidden',!on); p.hidden=!on;
      });
      if(window.hljs) document.querySelectorAll('pre code').forEach(el=>hljs.highlightElement(el));
    });
  }

  if(typeof Chart!=='undefined'){
    const ctx=document.getElementById('riskDonut');
    if(ctx) new Chart(ctx,{type:'doughnut',data:{
      labels:['Severity','Exploit','Reachability','Blast'],
      datasets:[{data:[CHART_SCORES.severity||0,CHART_SCORES.exploit||0,CHART_SCORES.reachability||0,CHART_SCORES.blast||0],
        backgroundColor:['#C53030','#dd6b20','#D69E2E','#805ad5']}]},
      options:{plugins:{legend:{position:'bottom'}},maintainAspectRatio:true}});
  }

  // ── Neo4j Browser-style Reachability Graph ─────────────────────────
  const NEO_COLORS = {
    cve:      '#F25F5C',
    package:  '#4FC1E9',
    cwe:      '#FFCE54',
    function: '#AC92EC',
    service:  '#48CFAD',
  };
  const NEO_LABELS = {
    cve: 'CVE', package: 'Package', cwe: 'CWE', function: 'Function', service: 'Service'
  };

  let network = null;
  let gNodes  = null;
  let gEdges  = null;

  function _buildSchemaPills(rawNodes, rawEdges, prefix) {
    // Count by type
    const typeCounts = {};
    rawNodes.forEach(n => { typeCounts[n.type] = (typeCounts[n.type] || 0) + 1; });
    const relCounts = {};
    rawEdges.forEach(e => { relCounts[e.label || e.kind] = (relCounts[e.label || e.kind] || 0) + 1; });

    // Node pills
    const nList = document.getElementById(prefix + '-node-pills');
    if (nList) {
      nList.innerHTML = '';
      Object.entries(typeCounts).forEach(([type, cnt]) => {
        const col = NEO_COLORS[type] || '#718096';
        const pill = document.createElement('span');
        pill.className = 'neo-npill';
        pill.style.background = col + '33';
        pill.style.border = '1px solid ' + col + '66';
        pill.innerHTML = '<span class="neo-ndot" style="background:' + col + '"></span>' +
          (NEO_LABELS[type] || type) + ' <span style="opacity:.7">(' + cnt + ')</span>';
        pill.onclick = () => filterByType(type);
        nList.appendChild(pill);
      });
    }

    // Rel pills
    const rList = document.getElementById(prefix + '-rel-pills');
    if (rList) {
      rList.innerHTML = '';
      Object.entries(relCounts).forEach(([rel, cnt]) => {
        const pill = document.createElement('span');
        pill.className = 'neo-rpill';
        pill.textContent = rel + ' (' + cnt + ')';
        rList.appendChild(pill);
      });
    }

    // Counts
    const nc = document.getElementById(prefix + '-ncount');
    const rc = document.getElementById(prefix + '-rcount');
    if (nc) nc.textContent = rawNodes.length;
    if (rc) rc.textContent = rawEdges.length;
  }

  function filterByType(type) {
    if (!gNodes || !gEdges) return;
    const hidden = new Set();
    gNodes.update((GRAPH_DATA.nodes || []).map(n => {
      const show = n.type === type;
      if (!show) hidden.add(n.id);
      return { id: n.id, hidden: !show };
    }));
    gEdges.update((GRAPH_DATA.edges || []).map((e, i) => ({
      id: i, hidden: hidden.has(e.source) || hidden.has(e.target),
    })));
  }

  window.initGraph = function () {
    if (network || typeof vis === 'undefined') return;
    const container = document.getElementById('graph-network');
    if (!container) return;

    const rawNodes = GRAPH_DATA.nodes || [];
    const rawEdges = GRAPH_DATA.edges || [];

    // Populate stat bar
    const stat = document.getElementById('neo-stat');
    if (stat) stat.textContent =
      'Started streaming ' + rawNodes.length + ' nodes, ' + rawEdges.length + ' edges';

    // Build schema panels
    _buildSchemaPills(rawNodes, rawEdges, 'schema');
    _buildSchemaPills(rawNodes, rawEdges, 'results');

    // Update query display with actual edge types present
    const relTypes = [...new Set(rawEdges.map(e => e.label || e.kind))];
    const qEl = document.getElementById('neo-query');
    if (qEl && relTypes.length) {
      const sample = relTypes.slice(0,2).join('|');
      qEl.textContent = 'MATCH p=()-[:' + sample + ']->() RETURN p LIMIT ' + rawNodes.length + ';';
    }

    // ── vis-network DataSets ──────────────────────────────────────────
    gNodes = new vis.DataSet(rawNodes.map(n => {
      const col = NEO_COLORS[n.type] || '#718096';
      
      let displayLabel = n.label || '';
      let nodeSize = 25;
      
      if (n.type === 'cve') {
        displayLabel = (n.severity || '').toUpperCase() || n.cve_id || n.label || 'CVE';
        nodeSize = 28;
      } else if (n.type === 'package') {
        displayLabel = n.package || (n.label || '').split('\n')[0];
        nodeSize = 32;
      } else if (n.type === 'service') {
        displayLabel = n.service || (n.label || '').split('\n')[0];
        nodeSize = 30;
      } else if (n.type === 'function') {
        displayLabel = n.label || 'fn';
        nodeSize = 20;
      } else if (n.type === 'cwe') {
        displayLabel = (n.label || '').split('\n')[0];
        nodeSize = 24;
      }
      
      return {
        id:       n.id,
        label:    displayLabel,
        shape:    'circle',
        size:     nodeSize,
        borderWidth: 2,
        color: {
          background: col,
          border:     col,
          highlight:  { background: col, border: '#ffffff' },
          hover:      { background: col, border: '#ffffff' },
        },
        font: { color: '#ffffff', size: 9, face: 'Inter,system-ui', bold: true },
        title:    (n.title || n.label || '').replace(/\n/g, '<br>'),
        nodeType: n.type,
        severity: n.severity || '',
        cvss:     n.cvss    || 0,
        fullLabel: n.label  || '',
      };
    }));

    gEdges = new vis.DataSet(rawEdges.map((e, i) => ({
      id:       i,
      from:     e.source,
      to:       e.target,
      label:    e.label || '',
      color:    { color: 'rgba(255,255,255,0.18)', highlight: 'rgba(255,255,255,0.7)', hover: 'rgba(255,255,255,0.45)' },
      dashes:   e.dashes || false,
      arrows:   { to: { enabled: true, scaleFactor: 0.45 } },
      font:     { size: 7, align: 'middle', color: 'rgba(255,255,255,0.45)', strokeWidth: 0, vadjust: -2 },
      edgeType: e.kind,
      smooth:   { type: 'continuous' },
    })));

    // ── Network ───────────────────────────────────────────────────────
    network = new vis.Network(
      container,
      { nodes: gNodes, edges: gEdges },
      {
        physics: {
          enabled: true,
          solver: 'forceAtlas2Based',
          forceAtlas2Based: {
            gravitationalConstant: -65,
            centralGravity: 0.012,
            springLength: 145,
            springConstant: 0.07,
            damping: 0.42,
          },
          stabilization: { iterations: 250, updateInterval: 25 },
        },
        interaction: {
          hover: true,
          tooltipDelay: 150,
          navigationButtons: false,
          keyboard: { enabled: true, speed: { x: 8, y: 8, zoom: 0.02 } },
          multiselect: false,
        },
        nodes: {
          borderWidth: 0,
          shadow: { enabled: true, color: 'rgba(0,0,0,0.4)', size: 10, x: 0, y: 4 },
        },
        edges: {
          smooth: { type: 'continuous' },
          width: 1.2,
          selectionWidth: 2,
        },
      }
    );

    // Auto-freeze physics
    network.on('stabilizationIterationsDone', () => {
      network.setOptions({ physics: { enabled: false } });
      const pbtn = document.getElementById('neo-phys-btn');
      if (pbtn) pbtn.title = 'Enable physics';
    });

    // ── Click: rich Neo4j-style detail panel ─────────────────────────
    network.on('click', params => {
      const panel = document.getElementById('graph-detail');
      if (!panel) return;
      const SEV_COL = { CRITICAL:'#C53030', HIGH:'#DD6B20', MEDIUM:'#D69E2E', LOW:'#38A169' };

      if (params.nodes.length > 0) {
        const n = rawNodes.find(x => x.id === params.nodes[0]);
        if (!n) return;
        const col = NEO_COLORS[n.type] || '#718096';
        const sc  = SEV_COL[n.severity] || '';
        const props = (n.title || '').split('\n').slice(1).filter(Boolean);
        panel.innerHTML =
          '<div class="neo-dl" style="color:' + col + '">' + (NEO_LABELS[n.type] || n.type || 'Node') + '</div>' +
          '<div class="neo-dn">' + (n.fullLabel || n.label || '').replace(/\n/g, '<br>') + '</div>' +
          (sc ? '<span class="neo-sev-badge" style="background:' + sc + '">' + n.severity + '</span>' +
                '<span class="neo-sev-badge" style="background:#4C8EDA">CVSS ' + n.cvss + '</span><br>' : '') +
          props.map(p => {
            const [k, ...rest] = p.split(':');
            return '<div class="neo-dr"><span class="neo-dk">' + k.trim() + '</span><span class="neo-dv">' + (rest.join(':').trim()) + '</span></div>';
          }).join('');

      } else if (params.edges.length > 0) {
        const e   = gEdges.get(params.edges[0]);
        const src = rawNodes.find(x => x.id === e.from);
        const tgt = rawNodes.find(x => x.id === e.to);
        panel.innerHTML =
          '<div class="neo-dl" style="color:#71869d">Relationship</div>' +
          '<div class="neo-dn" style="font-family:monospace">' + (e.label || e.edgeType || 'edge') + '</div>' +
          '<div class="neo-dr"><span class="neo-dk">From</span><span class="neo-dv">' + (src ? src.fullLabel || src.label : e.from).replace(/\n/g, ' ') + '</span></div>' +
          '<div class="neo-dr"><span class="neo-dk">To</span><span class="neo-dv">' + (tgt ? tgt.fullLabel || tgt.label : e.to).replace(/\n/g, ' ') + '</span></div>';

      } else {
        panel.innerHTML = '<p style="color:#71869d;font-size:.75rem;margin:0">Click a node or relationship to see its properties.</p>';
      }
    });
  };

  // Controls wired to neo-bottom toolbar buttons
  document.getElementById('neo-fit')?.addEventListener('click', () => {
    if (network) network.fit({ animation: { duration: 350, easingFunction: 'easeInOutQuad' } });
  });
  document.getElementById('neo-zin')?.addEventListener('click', () => {
    if (network) { const s = network.getScale(); network.moveTo({ scale: s * 1.25, animation: true }); }
  });
  document.getElementById('neo-zout')?.addEventListener('click', () => {
    if (network) { const s = network.getScale(); network.moveTo({ scale: s * 0.8, animation: true }); }
  });
  document.getElementById('neo-phys-btn')?.addEventListener('click', function() {
    if (!network) return;
    const cur = network.physics?.options?.enabled ?? false;
    network.setOptions({ physics: { enabled: !cur } });
    this.title = cur ? 'Enable physics' : 'Disable physics';
  });

  // View tabs (Graph / Table / RAW are cosmetic — graph is always shown)
  document.querySelectorAll('.neo-vtab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.neo-vtab').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    });
  });

  // Node-type filter pills wired via filterByType()
  // (clicking pills in schema panel already calls filterByType)
  document.getElementById('neo-show-all')?.addEventListener('click', () => {
    if (!gNodes || !gEdges) return;
    gNodes.update((GRAPH_DATA.nodes||[]).map(n => ({ id: n.id, hidden: false })));
    gEdges.update((GRAPH_DATA.edges||[]).map((e,i) => ({ id: i, hidden: false })));
  });





  if(window.hljs) hljs.highlightAll();
})();
</script>
</body>
</html>
