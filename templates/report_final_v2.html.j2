<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>{{ metadata.target_repo|default('project') }} · Pre-Upgrade Risk Report</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet"/>
<script src="https://cdn.jsdelivr.net/npm/vis-network@9.1.9/standalone/umd/vis-network.min.js" defer></script>
<style>
:root {
  --bg:          #f3f6fb;
  --bg-soft:     #eaf0f8;
  --surface:     #ffffff;
  --surface-2:   #f7faff;
  --surface-3:   #eef3fa;
  --border:      #d8e1ee;
  --border-2:    #c2cee0;

  --text:        #142036;
  --text-2:      #3b5478;
  --text-3:      #6a7e9c;

  --primary:     #1f4e79;
  --primary-2:   #2e75b6;
  --accent:      #6f59d9;

  --danger:      #c5304a;
  --danger-bg:   rgba(197,48,74,0.08);
  --warning:     #b06e00;
  --warning-bg:  rgba(176,110,0,0.1);
  --success:     #157a52;
  --success-bg:  rgba(21,122,82,0.1);
  --info:        #1f7bcc;
  --info-bg:     rgba(31,123,204,0.1);

  --radius-sm: 6px;
  --radius-md: 10px;
  --radius-lg: 14px;

  --shadow-sm: 0 1px 2px rgba(15,30,55,0.06);
  --shadow-md: 0 4px 12px rgba(15,30,55,0.08);
  --shadow-lg: 0 12px 28px rgba(15,30,55,0.10);

  --font-sans: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
  --font-mono: "JetBrains Mono", Consolas, Monaco, monospace;
}

html[data-theme="dark"] {
  --bg:          #0b121d;
  --bg-soft:     #0f1828;
  --surface:     #131d2e;
  --surface-2:   #18243a;
  --surface-3:   #1f2c46;
  --border:      #25334e;
  --border-2:    #2e3f5e;

  --text:        #e6edf8;
  --text-2:      #9fb1cc;
  --text-3:      #6a82a3;

  --primary:     #4fc3f7;
  --primary-2:   #66d4ff;
  --accent:      #a78bfa;

  --danger:      #ff6b85;
  --danger-bg:   rgba(255,107,133,0.12);
  --warning:     #ffb547;
  --warning-bg:  rgba(255,181,71,0.12);
  --success:     #34d399;
  --success-bg:  rgba(52,211,153,0.12);
  --info:        #5bbcff;
  --info-bg:     rgba(91,188,255,0.12);

  --shadow-sm: 0 1px 2px rgba(0,0,0,0.4);
  --shadow-md: 0 4px 14px rgba(0,0,0,0.45);
  --shadow-lg: 0 14px 30px rgba(0,0,0,0.55);
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  font-family: var(--font-sans);
  background: var(--bg);
  color: var(--text);
  font-size: 15.5px;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}
a { color: var(--primary-2); text-decoration: none; }
a:hover { text-decoration: underline; }
code, pre { font-family: var(--font-mono); }

.site-header {
  position: sticky; top: 0; z-index: 200;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
  box-shadow: var(--shadow-sm);
}
.header-inner {
  max-width: 1280px; margin: 0 auto;
  padding: 14px 24px;
  display: flex; align-items: center; gap: 20px; flex-wrap: wrap;
  justify-content: space-between;
}
.brand { display: flex; align-items: center; gap: 12px; }
.brand-mark {
  width: 32px; height: 32px;
  border-radius: 8px;
  background: linear-gradient(135deg, var(--primary), var(--accent));
  display: flex; align-items: center; justify-content: center;
  color: #fff; font-weight: 800; font-size: 15.5px;
}
.brand-meta h1 {
  font-size: 16px; font-weight: 700; color: var(--text);
  letter-spacing: -0.01em;
}
.brand-meta p {
  font-size: 13px; color: var(--text-3); margin-top: 2px;
  font-family: var(--font-mono);
}
.header-actions { display: flex; align-items: center; gap: 10px; }
.verdict-pill {
  display: flex; flex-direction: column; align-items: center;
  padding: 8px 18px; border-radius: 10px;
  font-weight: 700; color: #fff; min-width: 140px;
}
.verdict-pill .label { font-size: 14px; letter-spacing: 0.04em; }
.verdict-pill .score { font-size: 12px; opacity: 0.9; font-family: var(--font-mono); margin-top: 2px; }
.verdict-BLOCK { background: var(--danger); }
.verdict-REVIEW { background: var(--warning); color: #1a1106; }
.verdict-PROCEED { background: var(--success); }
.icon-btn {
  background: var(--surface-2); border: 1px solid var(--border);
  color: var(--text-2);
  padding: 8px 12px; border-radius: 8px; cursor: pointer;
  font-family: var(--font-mono); font-size: 12px;
  letter-spacing: 0.06em; text-transform: uppercase;
  transition: border-color .15s, color .15s, background .15s;
}
.icon-btn:hover { border-color: var(--primary-2); color: var(--primary-2); }
.icon-btn .ic { margin-right: 6px; }

.tab-bar {
  position: sticky; top: 64px; z-index: 190;
  background: var(--surface);
  border-bottom: 1px solid var(--border);
}
.tab-inner {
  max-width: 1280px; margin: 0 auto;
  padding: 6px 24px;
  display: flex; gap: 4px; flex-wrap: wrap;
}
.tab-btn {
  background: transparent;
  color: var(--text-2);
  border: 1px solid transparent;
  padding: 8px 14px;
  border-radius: 8px;
  font-size: 14px; font-weight: 500;
  font-family: inherit;
  cursor: pointer;
  transition: background .15s, color .15s, border-color .15s;
}
.tab-btn:hover { background: var(--surface-2); color: var(--text); }
.tab-btn[aria-selected="true"] {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}
.tab-btn:focus-visible { outline: 2px solid var(--primary-2); outline-offset: 2px; }
.tab-select {
  display: none;
  width: calc(100% - 48px);
  margin: 8px 24px;
  padding: 10px 12px;
  border: 1px solid var(--border);
  border-radius: 8px;
  font-size: 15.5px;
  background: var(--surface);
  color: var(--text);
}

main {
  max-width: 1280px; margin: 0 auto;
  padding: 28px 24px 64px;
}
.tab-panel { display: none; animation: fadein .25s ease both; }
.tab-panel.active { display: block; }
@keyframes fadein {
  from { opacity: 0; transform: translateY(6px); }
  to { opacity: 1; transform: translateY(0); }
}

.card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 24px;
  box-shadow: var(--shadow-sm);
  margin-bottom: 20px;
}
.card-title {
  font-size: 15px; font-weight: 700;
  color: var(--text);
  margin-bottom: 4px;
  letter-spacing: -0.01em;
}
.card-sub {
  font-size: 13px; color: var(--text-3);
  margin-bottom: 18px;
}
.section-head {
  display: flex; align-items: center; gap: 10px;
  font-size: 14px; font-weight: 700; color: var(--text);
  margin: 20px 0 12px;
}
.section-head::before {
  content: ""; display: inline-block;
  width: 3px; height: 14px;
  background: var(--primary-2);
  border-radius: 2px;
}
.muted { color: var(--text-3); }
.mono { font-family: var(--font-mono); }

.badge {
  display: inline-block;
  padding: 3px 10px;
  border-radius: 999px;
  font-size: 12px; font-weight: 600;
  letter-spacing: 0.03em;
  text-transform: uppercase;
}
.badge-BLOCK { background: var(--danger-bg); color: var(--danger); }
.badge-REVIEW { background: var(--warning-bg); color: var(--warning); }
.badge-PROCEED { background: var(--success-bg); color: var(--success); }
.badge-info { background: var(--info-bg); color: var(--info); }
.badge-neutral { background: var(--surface-3); color: var(--text-2); }
.badge-CRITICAL { background: var(--danger-bg); color: var(--danger); }
.badge-HIGH { background: var(--warning-bg); color: var(--warning); }
.badge-MODERATE { background: var(--info-bg); color: var(--info); }
.badge-LOW { background: var(--success-bg); color: var(--success); }
.badge-HARDENED_ONLY, .badge-INTERNAL_CHANGE, .badge-ADDED { background: var(--surface-3); color: var(--text-2); }
.badge-MODULE_REMOVED, .badge-CLASS_REMOVED, .badge-FUNCTION_REMOVED, .badge-METHOD_REMOVED, .badge-REMOVED, .badge-SIGNATURE_CHANGED, .badge-RENAMED { background: var(--danger-bg); color: var(--danger); }
.badge-RETURN_CHANGED { background: var(--warning-bg); color: var(--warning); }

.hero {
  background: linear-gradient(135deg, var(--surface) 0%, var(--surface-2) 100%);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 36px 32px;
  display: grid;
  grid-template-columns: 1.5fr 1fr;
  gap: 28px;
  align-items: center;
  box-shadow: var(--shadow-md);
  margin-bottom: 20px;
}
.hero-eyebrow {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-3);
  margin-bottom: 12px;
}
.hero-title {
  font-size: 28px;
  font-weight: 800;
  letter-spacing: -0.02em;
  line-height: 1.2;
  margin-bottom: 8px;
}
.hero-title .pkg { color: var(--primary-2); }
.hero-narrative {
  font-size: 15.5px;
  color: var(--text-2);
  max-width: 540px;
  line-height: 1.6;
}
.hero-fraction {
  text-align: center;
  padding: 20px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
}
.hero-num {
  font-size: 72px; font-weight: 800;
  color: var(--danger);
  line-height: 1; letter-spacing: -0.04em;
  font-feature-settings: "tnum";
}
.hero-of { font-size: 18px; color: var(--text-3); margin-left: 4px; font-weight: 500; }
.hero-sub { font-size: 14px; color: var(--text-2); margin-top: 8px; }

.kpi-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16px;
  margin-bottom: 20px;
}
.kpi {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 18px 20px;
  box-shadow: var(--shadow-sm);
}
.kpi-label {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-3);
  margin-bottom: 8px;
}
.kpi-value {
  font-size: 26px; font-weight: 700;
  letter-spacing: -0.02em;
  font-family: var(--font-mono);
}
.kpi-value.danger { color: var(--danger); }
.kpi-value.warning { color: var(--warning); }
.kpi-value.success { color: var(--success); }
.kpi-foot { font-size: 12px; color: var(--text-3); margin-top: 6px; }

.decision-card {
  display: grid;
  grid-template-columns: 200px 1fr;
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 1px solid var(--danger);
  background: var(--surface);
  box-shadow: var(--shadow-sm);
  margin-bottom: 20px;
}
.decision-card.is-review { border-color: var(--warning); }
.decision-card.is-proceed { border-color: var(--success); }
.decision-stamp {
  background: var(--danger-bg);
  border-right: 1px solid var(--border);
  padding: 28px 20px;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  gap: 6px;
}
.decision-card.is-review .decision-stamp { background: var(--warning-bg); }
.decision-card.is-proceed .decision-stamp { background: var(--success-bg); }
.decision-word {
  font-family: var(--font-mono);
  font-size: 30px; font-weight: 800;
  color: var(--danger);
  letter-spacing: 0.06em;
}
.decision-card.is-review .decision-word { color: var(--warning); }
.decision-card.is-proceed .decision-word { color: var(--success); }
.decision-tag {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--text-3);
}
.decision-body { padding: 24px 28px; display: flex; flex-direction: column; gap: 8px; }
.decision-head { font-size: 16px; font-weight: 700; color: var(--text); }
.decision-text { font-size: 14px; color: var(--text-2); line-height: 1.6; }
.decision-text code { color: var(--primary-2); background: var(--surface-3); padding: 1px 5px; border-radius: 3px; }

.overview-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
  margin-bottom: 20px;
}
.blast-list { list-style: none; }
.blast-list li {
  display: flex; justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px dashed var(--border);
  font-size: 14px;
}
.blast-list li:last-child { border-bottom: none; }
.blast-list .k { color: var(--text-2); }
.blast-list .v { font-family: var(--font-mono); font-weight: 700; color: var(--text); }
.blast-list .v.danger { color: var(--danger); }
.blast-list .v.warning { color: var(--warning); }
.blast-list .v.success { color: var(--success); }

.action-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-left: 3px solid var(--primary-2);
  border-radius: var(--radius-md);
  padding: 22px;
  box-shadow: var(--shadow-sm);
  margin-bottom: 20px;
}
.action-card h3 {
  font-size: 12px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--primary-2);
  margin-bottom: 14px;
}
.action-list { list-style: none; counter-reset: action; }
.action-list li {
  counter-increment: action;
  display: flex; gap: 14px; align-items: flex-start;
  padding: 12px 0;
  border-bottom: 1px solid var(--border);
  font-size: 14px;
  color: var(--text-2);
}
.action-list li:last-child { border-bottom: none; }
.action-list li::before {
  content: counter(action);
  flex-shrink: 0;
  width: 22px; height: 22px;
  border-radius: 50%;
  background: var(--info-bg);
  color: var(--info);
  font-family: var(--font-mono);
  font-size: 12px; font-weight: 700;
  display: flex; align-items: center; justify-content: center;
}
.action-list code {
  background: var(--surface-3);
  padding: 1px 6px;
  border-radius: 3px;
  font-size: 13px;
  color: var(--warning);
}

.toolbar {
  display: flex; flex-wrap: wrap; gap: 12px;
  align-items: center;
  padding: 14px 16px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  margin-bottom: 16px;
}
.toolbar input[type="search"],
.toolbar select {
  background: var(--surface-2);
  border: 1px solid var(--border);
  border-radius: 6px;
  color: var(--text);
  padding: 8px 10px;
  font-size: 14px;
  font-family: inherit;
}
.toolbar input[type="search"] { min-width: 240px; }
.toolbar label { font-size: 13px; color: var(--text-2); display: inline-flex; align-items: center; gap: 6px; }
.toolbar .count {
  margin-left: auto;
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--text-3);
  letter-spacing: 0.06em;
  text-transform: uppercase;
}

.data-table {
  width: 100%;
  border-collapse: collapse;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  margin-bottom: 20px;
}
.data-table th {
  text-align: left;
  background: var(--surface-3);
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-3);
  padding: 12px 14px;
  border-bottom: 1px solid var(--border);
  cursor: pointer;
  user-select: none;
}
.data-table th:hover { color: var(--primary-2); }
.data-table td {
  padding: 12px 14px;
  font-size: 14px;
  border-bottom: 1px solid var(--border);
  color: var(--text);
}
.data-table tr:last-child td { border-bottom: none; }
.data-table tr.main-row { cursor: pointer; transition: background .12s; }
.data-table tr.main-row:hover { background: var(--surface-2); }
.data-table tr.main-row.expanded { background: var(--surface-2); }
.data-table .cve-id { font-family: var(--font-mono); font-size: 13px; color: var(--text-2); }
.data-table .pkg { font-family: var(--font-mono); font-size: 13px; color: var(--primary-2); font-weight: 600; }
.cvss-cell { display: flex; align-items: center; gap: 8px; }
.cvss-cell .num { font-family: var(--font-mono); font-weight: 700; }
.mini-bar { width: 80px; height: 4px; background: var(--border); border-radius: 2px; overflow: hidden; }
.mini-bar > span { display: block; height: 100%; border-radius: 2px; }
.detail-row.hidden { display: none; }
.detail-row td { background: var(--surface-2); padding: 0; }
.detail-panel { padding: 22px 24px; border-top: 2px solid var(--primary-2); }
.detail-panel h4 {
  font-size: 12px;
  font-family: var(--font-mono);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-3);
  margin: 14px 0 8px;
}
.detail-panel h4:first-child { margin-top: 0; }
.score-bars { display: flex; flex-direction: column; gap: 8px; margin-top: 6px; }
.score-bar-row {
  display: grid;
  grid-template-columns: 110px 1fr 40px;
  align-items: center;
  gap: 12px;
  font-size: 13px;
}
.score-bar-row .lbl { color: var(--text-2); }
.score-bar-row .val { font-family: var(--font-mono); font-weight: 700; text-align: right; }
.bar-track { height: 6px; background: var(--border); border-radius: 3px; overflow: hidden; }
.bar-fill { height: 100%; border-radius: 3px; }
.bar-sev { background: var(--danger); }
.bar-exp { background: #dd6b20; }
.bar-reach { background: var(--warning); }
.bar-blast { background: var(--accent); }
.ref-list { list-style: none; font-size: 14px; }
.ref-list li {
  padding: 6px 0;
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--text-2);
}
.ref-list li code { color: var(--primary-2); }

.kev-yes { color: var(--danger); font-weight: 700; font-family: var(--font-mono); font-size: 13px; }
.kev-no { color: var(--text-3); font-family: var(--font-mono); font-size: 13px; }
.reach-yes { color: var(--warning); font-family: var(--font-mono); font-size: 13px; }
.reach-no { color: var(--success); font-family: var(--font-mono); font-size: 13px; }

.version-jump {
  display: flex; align-items: center; gap: 16px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 18px 22px;
  margin-bottom: 12px;
}
.ver-box {
  font-family: var(--font-mono);
  font-size: 15.5px; font-weight: 700;
  padding: 8px 14px;
  border: 1px solid var(--border);
  border-radius: 6px;
  background: var(--surface-2);
  color: var(--text-2);
}
.ver-box.target { color: var(--danger); border-color: var(--danger); background: var(--danger-bg); }
.ver-arrow { font-size: 18px; color: var(--text-3); }
.ver-tag {
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.08em;
  color: var(--warning);
  background: var(--warning-bg);
  padding: 3px 8px;
  border-radius: 4px;
}
.ver-desc { flex: 1; font-size: 13px; color: var(--text-2); line-height: 1.5; }

.conflict-block {
  background: var(--surface);
  border: 1px solid var(--border);
  border-left: 3px solid var(--danger);
  border-radius: var(--radius-md);
  padding: 18px 20px;
  margin-bottom: 12px;
  box-shadow: var(--shadow-sm);
}
.conflict-block.cascade { border-left-color: var(--warning); }
.conflict-title {
  font-family: var(--font-mono);
  font-size: 12px; font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--danger);
  margin-bottom: 10px;
}
.conflict-block.cascade .conflict-title { color: var(--warning); }
.conflict-line {
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--text-2);
  line-height: 1.8;
}
.conflict-line .pkg { color: var(--primary-2); font-weight: 600; }
.conflict-line .ver { color: var(--warning); }
.conflict-line .op { color: var(--text-3); }
.conflict-line .boom { color: var(--danger); font-weight: 700; }

.symbol-list { display: flex; flex-wrap: wrap; gap: 8px; margin: 12px 0; }
.symbol-chip {
  font-family: var(--font-mono);
  font-size: 13px;
  background: var(--warning-bg);
  color: var(--warning);
  border: 1px solid var(--warning);
  padding: 4px 10px;
  border-radius: 4px;
}

.semgrep-hit {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 16px 18px;
  margin-bottom: 10px;
}
.semgrep-file {
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--primary-2);
  margin-bottom: 6px;
  font-weight: 600;
}
.semgrep-note { font-size: 13px; color: var(--text-2); margin-bottom: 8px; }
.semgrep-match {
  display: inline-block;
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--danger);
  background: var(--danger-bg);
  padding: 4px 8px;
  border-radius: 4px;
}

.step-card {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 22px;
  margin-bottom: 14px;
  box-shadow: var(--shadow-sm);
  transition: box-shadow .2s;
}
.step-card:hover { box-shadow: var(--shadow-md); }
.step-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
.step-label { font-family: var(--font-mono); font-size: 12px; letter-spacing: 0.08em; text-transform: uppercase; color: var(--primary-2); font-weight: 700; }
.step-time { font-size: 12px; color: var(--text-3); font-family: var(--font-mono); }
.step-title { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 8px; }
.step-reason { font-size: 14px; color: var(--text-2); line-height: 1.6; margin-bottom: 12px; }
.step-reason strong { color: var(--text); }
.cmd-block {
  display: flex; align-items: center; gap: 10px;
  background: #0d1622;
  color: #d6e2f3;
  padding: 12px 14px;
  border-radius: var(--radius-sm);
  font-family: var(--font-mono);
  font-size: 13px;
  border: 1px solid #1a2b44;
}
html[data-theme="dark"] .cmd-block { background: #060a13; }
.cmd-block code { flex: 1; color: #d6e2f3; }
.btn-copy {
  padding: 4px 10px;
  border-radius: 4px;
  border: 1px solid #2c3f5c;
  background: transparent;
  color: #9fb1cc;
  font-family: var(--font-mono);
  font-size: 11px;
  cursor: pointer;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  transition: border-color .15s, color .15s;
}
.btn-copy:hover { border-color: var(--primary-2); color: var(--primary-2); }
.btn-copy.copied { border-color: var(--success); color: var(--success); }
.step-tests { font-size: 13px; color: var(--text-2); margin-top: 10px; }
.step-tests strong { color: var(--text); }

.mitigation-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }
.mitigation-list li {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 14px 16px;
  display: flex; gap: 12px;
  font-size: 14px;
  color: var(--text-2);
  line-height: 1.55;
  box-shadow: var(--shadow-sm);
}
.mitigation-list strong { color: var(--text); }
.mit-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }

.patch-select {
  width: 100%; max-width: 480px;
  background: var(--surface-2);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 10px 12px;
  border-radius: var(--radius-sm);
  font-size: 15.5px;
  margin-bottom: 18px;
  font-family: inherit;
}
.diff-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
  margin-bottom: 20px;
}
.diff-panel {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  overflow: hidden;
}
.diff-panel h3 {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 10px 14px;
  background: var(--surface-3);
  color: var(--text-3);
  border-bottom: 1px solid var(--border);
}
.diff-panel.before h3 { background: var(--danger-bg); color: var(--danger); }
.diff-panel.after h3 { background: var(--success-bg); color: var(--success); }
.diff-panel pre {
  padding: 14px 16px;
  font-size: 13px;
  font-family: var(--font-mono);
  line-height: 1.7;
  color: var(--text);
  overflow-x: auto;
  white-space: pre-wrap;
  word-break: break-word;
}
.usage-section {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 22px;
}
.usage-section h3 { font-size: 14px; font-weight: 700; color: var(--text); margin-bottom: 14px; }
.usage-site { margin-bottom: 14px; }
.usage-site:last-child { margin-bottom: 0; }
.usage-loc { font-family: var(--font-mono); font-size: 13px; color: var(--primary-2); margin-bottom: 6px; }
.usage-code {
  background: var(--surface-3);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 10px 12px;
  font-family: var(--font-mono);
  font-size: 13px;
  color: var(--text);
  overflow-x: auto;
  line-height: 1.6;
  white-space: pre-wrap;
}

.code-diff {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background-color: var(--border);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  overflow: hidden;
  margin: 12px 0;
}
.diff-old, .diff-new {
  background-color: var(--surface);
  padding: 12px;
  font-family: var(--font-mono);
  font-size: 13.5px;
}
.diff-old {
  background-color: var(--danger-bg);
  color: var(--text);
  border-right: 1px solid var(--border);
}
.diff-new {
  background-color: var(--success-bg);
  color: var(--text);
}
@media (max-width: 768px) {
  .code-diff {
    grid-template-columns: 1fr;
  }
  .diff-old {
    border-right: none;
    border-bottom: 1px solid var(--border);
  }
}

.graph-wrap {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 22px;
  margin-bottom: 18px;
  overflow-x: auto;
}

.live-graph-card { padding-bottom: 18px; }
.live-graph-header {
  display: flex; align-items: center; flex-wrap: wrap; gap: 12px;
  margin-bottom: 8px;
}
.live-graph-header .card-title { flex: 1; min-width: 220px; margin-bottom: 0; }
.live-graph-status {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 4px 10px; border-radius: 999px;
  font-family: var(--font-mono); font-size: 11px;
  font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase;
}
.live-graph-status .live-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: currentColor; flex-shrink: 0;
  box-shadow: 0 0 0 3px rgba(21,122,82,0.18);
}
.live-graph-status.is-live { background: var(--success-bg); color: var(--success); }
.live-graph-status.is-snapshot { background: var(--info-bg); color: var(--info); }
.live-graph-status.is-fallback { background: var(--warning-bg); color: var(--warning); }
.live-graph-status.is-fallback .live-dot,
.live-graph-status.is-snapshot .live-dot { box-shadow: none; }

.graph-toolbar {
  display: flex; flex-wrap: wrap; gap: 8px;
  margin: 14px 0 12px;
}
.graph-toolbar button {
  background: var(--surface-2);
  border: 1px solid var(--border);
  color: var(--text-2);
  padding: 6px 12px;
  border-radius: 6px;
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  cursor: pointer;
  transition: border-color .15s, color .15s, background .15s;
}
.graph-toolbar button:hover { border-color: var(--primary-2); color: var(--primary-2); }
.graph-toolbar button.is-active {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

.live-graph-canvas {
  width: 100%; height: 480px;
  background: var(--surface-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  position: relative;
}
.live-graph-canvas:focus { outline: 2px solid var(--primary-2); outline-offset: 2px; }
.live-graph-empty {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  color: var(--text-3); font-size: 13px;
  text-align: center; padding: 20px;
}
.live-graph-legend {
  display: flex; flex-wrap: wrap; gap: 18px;
  margin-top: 14px;
  padding: 10px 14px;
  background: var(--surface-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 12px;
  color: var(--text-2);
}
.live-graph-legend .legend-item {
  display: inline-flex; align-items: center; gap: 6px;
  font-family: var(--font-mono);
}
.live-graph-legend .swatch {
  width: 12px; height: 12px; border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.1);
}
.live-graph-legend .swatch.pkg { background: #4FC1E9; }
.live-graph-legend .swatch.cve { background: #F25F5C; }
.live-graph-legend .swatch.svc { background: #48CFAD; }
.live-graph-legend .swatch.fn  { background: #AC92EC; }
.live-graph-meta {
  display: flex; flex-wrap: wrap; gap: 18px;
  margin-top: 10px;
  font-family: var(--font-mono);
  font-size: 11px;
  color: var(--text-3);
}
.live-graph-meta strong { color: var(--text-2); }

.graph-caption {
  font-family: var(--font-mono);
  font-size: 12px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-3);
  margin-bottom: 14px;
}
.dep-tree {
  font-family: var(--font-mono);
  font-size: 13px;
  line-height: 1.85;
  color: var(--text-2);
  white-space: pre;
}
.dt-node { color: var(--primary-2); font-weight: 700; }
.dt-conn { color: var(--text-3); }
.dt-warn { color: var(--danger); font-weight: 700; font-size: 11px; letter-spacing: 0.05em; }

.cypher-block {
  background: var(--bg-soft);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 18px 22px;
  font-family: var(--font-mono);
  font-size: 13px;
  line-height: 1.85;
  color: var(--text-2);
  margin-bottom: 18px;
}
.cypher-node { color: var(--primary-2); font-weight: 700; }
.cypher-rel { color: var(--warning); }
.cypher-arrow { color: var(--text-3); }
.cypher-comment { color: var(--text-3); font-style: italic; }

.blast-svg { width: 100%; max-width: 100%; height: auto; }
.graph-legend { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 14px; font-size: 13px; color: var(--text-2); }
.legend-row { display: flex; align-items: center; gap: 6px; }
.legend-dot { width: 10px; height: 10px; border-radius: 50%; }

.formula-block {
  background: var(--bg-soft);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 22px;
  font-family: var(--font-mono);
  font-size: 13px;
  line-height: 1.85;
  color: var(--text-2);
  margin-bottom: 20px;
  white-space: pre-wrap;
}

.score-breakdown-table {
  width: 100%;
  border-collapse: collapse;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  margin-bottom: 20px;
}
.score-breakdown-table th {
  text-align: left;
  background: var(--surface-3);
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-3);
  padding: 12px 14px;
  border-bottom: 1px solid var(--border);
}
.score-breakdown-table td {
  padding: 12px 14px;
  font-size: 14px;
  border-bottom: 1px solid var(--border);
}
.score-breakdown-table tr:last-child td { border-bottom: none; }
.score-breakdown-table tr.total-row { background: var(--danger-bg); }
.score-breakdown-table tr.total-row td { font-weight: 700; }
.contrib-bar-wrap {
  width: 120px; height: 4px;
  background: var(--border);
  border-radius: 2px;
  overflow: hidden;
  display: inline-block;
  vertical-align: middle;
  margin-left: 10px;
}
.contrib-bar { height: 100%; border-radius: 2px; }

.raw-json {
  background: #0d1622;
  border: 1px solid var(--border);
  border-radius: var(--radius-md);
  padding: 20px;
  font-family: var(--font-mono);
  font-size: 13px;
  line-height: 1.55;
  color: #d6e2f3;
  overflow-x: auto;
  margin-bottom: 20px;
  white-space: pre-wrap;
  word-break: break-word;
}
html[data-theme="dark"] .raw-json { background: #050a13; }

.meta-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 12px;
}
.meta-item {
  background: var(--surface-2);
  border: 1px solid var(--border);
  border-radius: var(--radius-sm);
  padding: 12px 14px;
  font-size: 14px;
}
.meta-item .k {
  display: block;
  font-family: var(--font-mono);
  font-size: 11px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--text-3);
  margin-bottom: 4px;
}
.meta-item .v { color: var(--text); font-family: var(--font-mono); }
.meta-item .v.danger { color: var(--danger); }
.meta-item .v.success { color: var(--success); }
.meta-item .v.warning { color: var(--warning); }

.empty-state {
  background: var(--surface-2);
  border: 1px dashed var(--border);
  border-radius: var(--radius-md);
  padding: 32px 24px;
  text-align: center;
  color: var(--text-3);
  font-size: 14px;
}

.site-footer {
  text-align: center;
  padding: 28px 24px;
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--text-3);
  letter-spacing: 0.04em;
  border-top: 1px solid var(--border);
}

@media (max-width: 980px) {
  .hero { grid-template-columns: 1fr; }
  .decision-card { grid-template-columns: 1fr; }
  .decision-stamp { border-right: none; border-bottom: 1px solid var(--border); }
  .kpi-grid { grid-template-columns: repeat(2, 1fr); }
  .overview-grid { grid-template-columns: 1fr; }
  .diff-grid { grid-template-columns: 1fr; }
}
@media (max-width: 720px) {
  .tab-inner { display: none; }
  .tab-select { display: block; }
  .tab-bar { top: 56px; }
  .header-inner { padding: 12px 16px; gap: 12px; }
  main { padding: 20px 16px 48px; }
}
@media print {
  .site-header, .tab-bar, .toolbar, .icon-btn, .btn-copy, .tab-select { display: none !important; }
  .tab-panel { display: block !important; page-break-after: always; }
  body { background: #fff; }
}
</style>
</head>
<body>

{% set rec = (overall.recommendation or 'PROCEED')|upper %}
{% set rec_class_name = rec if rec in ['BLOCK','REVIEW','PROCEED'] else 'PROCEED' %}
{% set ri = risk_intelligence or {} %}
{% set top = ri.top_cve %}
{% set blast = ri.blast or {} %}

<header class="site-header">
  <div class="header-inner">
    <div class="brand">
      <div class="brand-mark">PR</div>
      <div class="brand-meta">
        <h1>Predictive Risk Assessment</h1>
        <p>{{ metadata.target_repo|default('project') }}{% if top and top.package %} · {{ top.package }} {{ top.fixed_version or '' }}{% endif %}</p>
      </div>
    </div>
    <div class="header-actions">
      <div class="verdict-pill verdict-{{ rec_class_name }}" aria-label="Overall recommendation">
        <span class="label">{{ rec }}</span>
        <span class="score">{{ overall.raw_risk|fmt_num(0) }} / 100 risk</span>
      </div>
      <button id="theme-toggle" class="icon-btn" type="button" aria-label="Toggle theme">
        <span class="ic">◐</span><span class="theme-label">Light</span>
      </button>
      <button class="icon-btn" type="button" onclick="window.print()" aria-label="Download PDF">
        <span class="ic">↓</span>PDF
      </button>
    </div>
  </div>
</header>

<nav class="tab-bar" aria-label="Report sections">
  <div class="tab-inner" role="tablist" id="tablist">
    <button role="tab" id="tab-overview" class="tab-btn" aria-selected="true" aria-controls="panel-overview" data-tab="overview">Overview</button>
    <button role="tab" id="tab-risks" class="tab-btn" aria-selected="false" aria-controls="panel-risks" data-tab="risks">Risks &amp; Findings</button>
    <button role="tab" id="tab-fixplan" class="tab-btn" aria-selected="false" aria-controls="panel-fixplan" data-tab="fixplan">Fix Plan</button>
    <button role="tab" id="tab-patches" class="tab-btn" aria-selected="false" aria-controls="panel-patches" data-tab="patches">Patches</button>
    <button role="tab" id="tab-graph" class="tab-btn" aria-selected="false" aria-controls="panel-graph" data-tab="graph">Graph</button>
    <button role="tab" id="tab-audit" class="tab-btn" aria-selected="false" aria-controls="panel-audit" data-tab="audit">Audit &amp; Evidence</button>
  </div>
  <select class="tab-select" id="tab-select-mobile" aria-label="Select report section">
    <option value="overview">Overview</option>
    <option value="risks">Risks &amp; Findings</option>
    <option value="fixplan">Fix Plan</option>
    <option value="patches">Patches</option>
    <option value="graph">Graph</option>
    <option value="audit">Audit &amp; Evidence</option>
  </select>
</nav>

<main>

<!-- TAB 1 · OVERVIEW -->
<section id="panel-overview" class="tab-panel active" role="tabpanel" aria-labelledby="tab-overview">

  <div class="hero">
    <div>
      <div class="hero-eyebrow">
        Pre-Upgrade Risk Assessment
        {% if github_url %}
        <span class="badge badge-info" style="margin-left: 8px; text-transform: none; font-family: var(--font-sans); padding: 2px 8px;">Source: GitHub — {{ github_url }}</span>
        {% endif %}
      </div>
      <h2 class="hero-title">Upgrade Risk: <span class="pkg">{% if version_jump %}{{ version_jump.package }} {{ version_jump.from_version }} → {{ version_jump.to_version }}{% elif top %}{{ top.package }}{% else %}{{ metadata.target_repo|default('project') }}{% endif %}</span></h2>
      <p class="hero-narrative">{{ narrative or 'Review the findings below before upgrading dependencies.' }}</p>
      {% if import_usages %}
        <div style="margin-top: 12px; display: flex; gap: 8px; flex-wrap: wrap;">
          {% for pkg, usage in import_usages.items() %}
            <span class="badge {% if usage.is_used %}badge-warning{% else %}badge-neutral{% endif %}" style="text-transform: none; font-size: 13px; font-family: var(--font-mono); padding: 4px 10px;">
              {{ pkg }}: {% if usage.is_used %}● Active ({{ usage.usage_count }} usages){% else %}○ Unused{% endif %}
            </span>
          {% endfor %}
        </div>
      {% endif %}
    </div>
    <div class="hero-fraction" aria-label="{{ blast.reachable_cves }} of {{ blast.total_cves }} CVEs reachable">
      <div>
        <span class="hero-num">{{ blast.reachable_cves|default(0) }}</span><span class="hero-of">/ {{ blast.total_cves|default(0) }}</span>
      </div>
      <p class="hero-sub">CVEs reachable in application code</p>
    </div>
  </div>

  <div class="decision-card {% if rec == 'REVIEW' %}is-review{% elif rec == 'PROCEED' %}is-proceed{% endif %}">
    <div class="decision-stamp">
      <div class="decision-word">{{ rec }}</div>
      <div class="decision-tag">Upgrade Decision</div>
    </div>
    <div class="decision-body">
      <div class="decision-head">{{ ri.headline or narrative or 'Upgrade decision summary' }}</div>
      <p class="decision-text">{{ overall.headline or narrative or 'Review the Risks, Fix Plan, and Audit tabs for the supporting evidence.' }}</p>
    </div>
  </div>

  <div class="kpi-grid">
    <div class="kpi">
      <div class="kpi-label">Risk Score</div>
      <div class="kpi-value {% if rec == 'BLOCK' %}danger{% elif rec == 'REVIEW' %}warning{% else %}success{% endif %}">{{ overall.raw_risk|fmt_num(0) }}<span style="font-size:15.5px;color:var(--text-3);"> / 100</span></div>
      <div class="kpi-foot">Readiness {{ ri.readiness_score|default(0) }} / 100</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Worst CVE</div>
      {% if top %}
      <div class="kpi-value {% if (top.cvss or 0) >= 9 %}danger{% elif (top.cvss or 0) >= 7 %}warning{% else %}success{% endif %}" style="font-size:18px;">{{ top.id }}</div>
      <div class="kpi-foot">CVSS {{ top.cvss|fmt_num(1) }} · EPSS {{ top.epss|fmt_pct }}{% if top.in_kev %} · KEV{% endif %}</div>
      {% else %}
      <div class="kpi-value success" style="font-size:18px;">None</div>
      <div class="kpi-foot">No CVEs scored</div>
      {% endif %}
    </div>
    <div class="kpi">
      <div class="kpi-label">Build Blockers</div>
      <div class="kpi-value {% if summary_stats.build_blockers|default(0) > 0 %}danger{% else %}success{% endif %}">{{ summary_stats.build_blockers|default(0) }}</div>
      <div class="kpi-foot">{% if conflicts %}{{ conflicts|length }} dependency conflict{{ 's' if conflicts|length != 1 else '' }}{% else %}No dependency conflicts{% endif %}</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Affected Services</div>
      <div class="kpi-value {% if (blast.affected_services or 0) >= 2 %}warning{% elif (blast.affected_services or 0) > 0 %}warning{% else %}success{% endif %}">{{ blast.affected_services|default(0) }}</div>
      <div class="kpi-foot">{{ ri.critical_services|join(', ') if ri.critical_services else '—' }}</div>
    </div>
  </div>

  <div class="overview-grid">
    <div class="card">
      <h3 class="card-title">Blast Radius Summary</h3>
      <p class="card-sub">Reach from vulnerable code into production services.</p>
      <ul class="blast-list">
        <li><span class="k">Affected Packages</span><span class="v {% if blast.affected_packages|default(0) > 0 %}danger{% endif %}">{{ blast.affected_packages|default(0) }}</span></li>
        <li><span class="k">Affected Services</span><span class="v {% if blast.affected_services|default(0) > 0 %}warning{% endif %}">{{ blast.affected_services|default(0) }}</span></li>
        <li><span class="k">Critical Services</span><span class="v">{{ ri.critical_services|join(', ') if ri.critical_services else '—' }}</span></li>
        <li><span class="k">Reachable CVEs</span><span class="v {% if blast.reachable_cves|default(0) > 0 %}warning{% endif %}">{{ blast.reachable_cves|default(0) }} / {{ blast.total_cves|default(0) }}</span></li>
        <li><span class="k">KEV Listed</span><span class="v {% if blast.kev_listed|default(0) > 0 %}danger{% endif %}">{{ 'YES' if blast.kev_listed|default(0) > 0 else 'NO' }}</span></li>
        <li><span class="k">Direct Dependencies</span><span class="v">{{ sbom.direct_dependencies|default(0) }}</span></li>
        <li><span class="k">Transitive Dependencies</span><span class="v">{{ sbom.transitive_dependencies|default(0) }}</span></li>
      </ul>
    </div>

    <div class="action-card">
      <h3>Recommended Actions</h3>
      {% if recommended_actions %}
      <ol class="action-list">
        {% for action in recommended_actions %}
        <li>{{ action|safe }}</li>
        {% endfor %}
      </ol>
      {% else %}
      <p class="muted" style="font-size:14px;">No remediation required — proceed with the upgrade.</p>
      {% endif %}
    </div>
  </div>
</section>

<!-- TAB 2 · RISKS & FINDINGS -->
<section id="panel-risks" class="tab-panel" role="tabpanel" aria-labelledby="tab-risks">

  <div class="card">
    <h3 class="card-title">Vulnerable Packages</h3>
    <p class="card-sub">CVEs detected in the dependency graph with reachability and exploitation context.</p>

    <div class="toolbar">
      <input id="findings-search" type="search" placeholder="Search CVE, package, or status..." aria-label="Search findings"/>
      <select id="findings-verdict" aria-label="Filter by verdict">
        <option value="all">All verdicts</option>
        <option value="BLOCK">BLOCK</option>
        <option value="REVIEW">REVIEW</option>
        <option value="PROCEED">PROCEED</option>
      </select>
      <label><input type="checkbox" id="findings-reachable"/> Only reachable</label>
      <span class="count" id="findings-count">Showing 0 of 0</span>
    </div>

    {% if cves %}
    <table class="data-table" id="risks-table">
      <thead>
        <tr>
          <th>CVE ID</th>
          <th>Package</th>
          <th>CVSS</th>
          <th>EPSS</th>
          <th>KEV</th>
          <th>Reach</th>
          <th>Score</th>
          <th>Verdict</th>
        </tr>
      </thead>
      <tbody>
        {% for c in cves %}
        {% set sev_class = c.recommendation or 'PROCEED' %}
        {% set cvss_v = c.cvss|default(0) %}
        {% set cvss_pct = ((cvss_v / 10) * 100)|round|int %}
        {% set cvss_color = 'var(--danger)' if cvss_v >= 7 else 'var(--warning)' if cvss_v >= 4 else 'var(--info)' %}
        <tr class="main-row" data-verdict="{{ c.recommendation }}" data-reachable="{{ 1 if c.is_reachable else 0 }}" tabindex="0" aria-expanded="false">
          <td><span class="cve-id">{{ c.cve_id }}</span></td>
          <td><span class="pkg">{{ c.package }}</span></td>
          <td>
            <div class="cvss-cell">
              <span class="num" style="color:{{ cvss_color }}">{{ c.cvss|fmt_num(1) }}</span>
              <div class="mini-bar"><span style="width:{{ cvss_pct }}%;background:{{ cvss_color }}"></span></div>
            </div>
          </td>
          <td><span class="mono" style="color:var(--warning)">{{ c.epss|fmt_pct }}</span></td>
          <td class="{{ 'kev-yes' if c.in_kev else 'kev-no' }}">{{ '● YES' if c.in_kev else '— NO' }}</td>
          <td class="{{ 'reach-yes' if c.is_reachable else 'reach-no' }}">{{ '● Reachable' if c.is_reachable else '— Not reached' }}</td>
          <td><span class="mono" style="font-weight:700;">{{ c.raw_risk|fmt_num(0) }}</span></td>
          <td><span class="badge badge-{{ sev_class }}">{{ c.recommendation }}</span></td>
        </tr>
        <tr class="detail-row hidden">
          <td colspan="8">
            <div class="detail-panel">
              {% if c.references %}
              <h4>Locations in your code</h4>
              <ul class="ref-list">
                {% for r in c.references %}
                {% set ep = r.entry_point_info or {} %}
                <li><code>{{ r.file }}:{{ r.line }}</code>{% if r.enclosing_function %} in <em>{{ r.enclosing_function }}</em>{% endif %}{% if ep.route %} ({{ ep.method or 'GET' }} {{ ep.route }}){% endif %}</li>
                {% endfor %}
              </ul>
              {% else %}
              <h4>Reachability</h4>
              <p style="font-size:14px;color:var(--text-3);">Not directly referenced in scanned application code.</p>
              {% endif %}
              <h4>Score breakdown</h4>
              <div class="score-bars">
                {% set sev = c.scores.severity_score|default(0) %}
                {% set exp = c.scores.exploit_score|default(0) %}
                {% set rch = c.scores.reachability_score|default(0) %}
                {% set bls = c.scores.blast_radius_score|default(0) %}
                <div class="score-bar-row"><span class="lbl">Severity</span><div class="bar-track"><div class="bar-fill bar-sev" style="width:{{ ((sev / 40) * 100)|round|int }}%"></div></div><span class="val">{{ sev }}</span></div>
                <div class="score-bar-row"><span class="lbl">Exploit</span><div class="bar-track"><div class="bar-fill bar-exp" style="width:{{ ((exp / 20) * 100)|round|int }}%"></div></div><span class="val">{{ exp }}</span></div>
                <div class="score-bar-row"><span class="lbl">Reachability</span><div class="bar-track"><div class="bar-fill bar-reach" style="width:{{ ((rch / 25) * 100)|round|int }}%"></div></div><span class="val">{{ rch }}</span></div>
                <div class="score-bar-row"><span class="lbl">Blast Radius</span><div class="bar-track"><div class="bar-fill bar-blast" style="width:{{ ((bls / 15) * 100)|round|int }}%"></div></div><span class="val">{{ bls }}</span></div>
              </div>
              {% if c.explanation %}
              <h4>Summary</h4>
              <p style="font-size:14px;color:var(--text-2);line-height:1.6;">{{ c.explanation }}</p>
              {% endif %}
              <h4>Fixed in</h4>
              <p style="font-size:14px;"><code style="color:var(--success);font-family:var(--font-mono);">{{ c.fixed_version or 'no upstream patch' }}</code></p>
            </div>
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
    {% else %}
    <div class="empty-state">No CVEs were found for this scan.</div>
    {% endif %}
  </div>

  {% if version_jump %}
  <div class="card">
    <h3 class="card-title">Version Upgrade Analysis</h3>
    <p class="card-sub">Direction and magnitude of the proposed version change.</p>
    <div class="version-jump">
      <div class="ver-box">{{ version_jump.package }} {{ version_jump.from_version }}</div>
      <div class="ver-arrow">→</div>
      <div class="ver-box target">{{ version_jump.package }} {{ version_jump.to_version }}</div>
      <div class="ver-desc">
        {% if version_jump.is_major %}
        <div class="ver-tag" style="margin-bottom:6px;display:inline-block;">MAJOR VERSION JUMP</div>
        {% endif %}
        <div>{{ version_jump.description }}</div>
      </div>
    </div>
  </div>
  {% endif %}

  {% if conflicts %}
  <div class="card">
    <h3 class="card-title">Dependency Conflicts</h3>
    <p class="card-sub">Constraint clashes detected by the upgrade simulator.</p>

    {% for conflict in conflicts %}
    <div class="conflict-block">
      <div class="conflict-title">Class A · Direct Conflict — {{ conflict.shared_dependency }}</div>
      <div class="conflict-line">
        {% for p in conflict.conflicting_packages %}
        <span class="pkg">{{ p.package }}</span> <span class="op">requires</span> <span class="ver">{{ p.constraint }}</span>{% if not loop.last %}<br/>{% endif %}
        {% endfor %}
        {% if conflict.would_break_build %}
        <br/><span style="color:var(--text-3);">──────────────────────</span><br/>
        <span class="boom">✕ UNSATISFIABLE — would break dependency resolution</span>
        {% endif %}
      </div>
      {% if conflict.human_explanation %}
      <div style="margin-top:10px;font-size:13px;color:var(--text-2);font-family:var(--font-sans);">{{ conflict.human_explanation }}</div>
      {% endif %}
    </div>
    {% endfor %}

    {% if cascade and cascade.chain %}
    <div class="conflict-block cascade">
      <div class="conflict-title">Class B · Cascade Chain</div>
      <div class="conflict-line">
        <span class="op">Trigger:</span> <span class="pkg">{{ cascade.trigger }}</span><br/>
        {% for link in cascade.chain %}
        <span class="op">{{ '  ' * loop.index0 }}↳ </span><span class="pkg">{{ link.package }}</span> <span class="op">{{ link['from'] }} → {{ link.to }}</span> <span class="op">(forced by {{ link.forced_by }})</span>{% if not loop.last %}<br/>{% endif %}
        {% endfor %}
      </div>
    </div>
    {% endif %}
  </div>
  {% endif %}

  {% if changed_symbols %}
  <div class="card">
    <h3 class="card-title">Changed Symbols &amp; APIs</h3>
    <p class="card-sub">Symbols flagged by patch analysis across reachable CVEs.</p>
    <div class="symbol-list">
      {% for s in changed_symbols %}
      <span class="symbol-chip" title="{{ s.classification }}">{{ s.name }}</span>
      {% endfor %}
    </div>
    <div style="font-size:13px;color:var(--text-2);line-height:1.7;">
      {% set removed = changed_symbols|selectattr('classification','equalto','REMOVED')|list %}
      {% set modified = changed_symbols|selectattr('classification','equalto','SIGNATURE_CHANGED')|list %}
      {% if removed %}<span style="color:var(--danger);font-family:var(--font-mono);font-size:12px;">● REMOVED:</span> {{ removed|length }} symbol(s) deleted upstream.{% endif %}
      {% if modified %} <span style="color:var(--warning);font-family:var(--font-mono);font-size:12px;">● MODIFIED:</span> {{ modified|length }} signature change(s).{% endif %}
    </div>
  </div>
  {% endif %}

  {% if semgrep_hits %}
  <div class="card">
    <h3 class="card-title">Semgrep &amp; Reachability Findings</h3>
    <p class="card-sub">Locations in this repository that call vulnerable or changed APIs.</p>

    {% for hit in semgrep_hits %}
    <div class="semgrep-hit">
      <div class="semgrep-file">{{ hit.file }}{% if hit.line %} : line {{ hit.line }}{% endif %}{% if hit.cve_id %} · <span style="color:var(--text-3);font-weight:400;">{{ hit.cve_id }}</span>{% endif %}</div>
      <div class="semgrep-note">
        {% if hit.route %}Reachable via <code>{{ hit.method or 'GET' }} {{ hit.route }}</code>{% if hit.enclosing_function %} in <em>{{ hit.enclosing_function }}</em>{% endif %}.
        {% elif hit.enclosing_function %}Inside <em>{{ hit.enclosing_function }}</em>.
        {% else %}Direct usage of {{ hit.symbol or hit.package }}.{% endif %}
      </div>
      {% if hit.snippet %}<span class="semgrep-match">{{ hit.snippet }}</span>{% endif %}
    </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if import_usages %}
  <div class="card">
    <h3 class="card-title">Active Package Usage</h3>
    <p class="card-sub">Files and imports indicating that target dependencies are actively used in the codebase.</p>
    {% for pkg, usage in import_usages.items() %}
      <div style="margin-bottom: 20px;">
        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 8px;">
          <span style="font-family: var(--font-mono); font-size: 15px; font-weight: 700; color: var(--primary-2);">{{ pkg }}</span>
          <span class="badge {% if usage.is_used %}badge-warning{% else %}badge-neutral{% endif %}">
            {% if usage.is_used %}In Use ({{ usage.usage_count }} occurrences){% else %}Not Used{% endif %}
          </span>
        </div>
        {% if usage.usages %}
          <div style="display: flex; flex-direction: column; gap: 8px; max-height: 250px; overflow-y: auto; border: 1px solid var(--border); border-radius: var(--radius-sm); padding: 12px; background: var(--surface-2);">
            {% for u in usage.usages %}
              <div style="font-size: 13.5px; display: flex; flex-direction: column; gap: 4px;">
                <div style="font-family: var(--font-mono); color: var(--text-2); font-weight: 600;">
                  {{ u.file }} : Line {{ u.line }}
                </div>
                <pre style="margin: 0; padding: 6px 10px; font-family: var(--font-mono); font-size: 12px; background: var(--surface-3); border-radius: 4px; color: var(--text); border: 1px solid var(--border); white-space: pre-wrap; word-break: break-all;">{{ u.match_text }}</pre>
              </div>
            {% endfor %}
          </div>
        {% else %}
          <p class="muted" style="font-size: 13.5px; padding-left: 4px;">No active import usages found in codebase.</p>
        {% endif %}
      </div>
    {% endfor %}
  </div>
  {% endif %}

  {% if api_changes %}
  <div class="card">
    <h3 class="card-title">AST API Breaking Changes</h3>
    <p class="card-sub">Interface signature diffs and removed components between the installed and upgraded package version.</p>
    <table class="data-table">
      <thead>
        <tr>
          <th>Symbol</th>
          <th>Change Type</th>
          <th>Old Signature</th>
          <th>New Signature</th>
          <th>Description</th>
        </tr>
      </thead>
      <tbody>
        {% for change in api_changes %}
        <tr>
          <td><span class="pkg" style="word-break: break-all;">{{ change.symbol }}</span></td>
          <td><span class="badge badge-{{ change.change_type }}">{{ change.change_type }}</span></td>
          <td><span class="mono" style="font-size:12px; color: var(--danger);">{{ change.old_signature or '—' }}</span></td>
          <td><span class="mono" style="font-size:12px; color: var(--success);">{{ change.new_signature or '—' }}</span></td>
          <td style="font-size: 13.5px; line-height: 1.5; color: var(--text-2);">{{ change.description }}</td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}

  {% if code_usages %}
  <div class="card">
    <h3 class="card-title">Smart Code Scan · Impacted Usages</h3>
    <p class="card-sub">Specific lines in your codebase affected by the API breaking changes identified above.</p>
    <div style="display: flex; flex-direction: column; gap: 14px;">
      {% for usage in code_usages %}
      <div style="border: 1px solid var(--border); border-radius: var(--radius-md); padding: 16px; background: var(--surface);">
        <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 8px; margin-bottom: 8px;">
          <div style="font-family: var(--font-mono); font-size: 13.5px; font-weight: 700; color: var(--primary-2);">
            {{ usage.file }}:{{ usage.line }}:{{ usage.col }}
          </div>
          <span class="badge badge-{{ usage.change_type }}">{{ usage.change_type }}</span>
        </div>
        <div style="font-size: 13px; color: var(--text-3); margin-bottom: 8px; font-family: var(--font-mono);">
          Reference to: <strong style="color: var(--text-2);">{{ usage.matched_symbol }}</strong>
        </div>
        <pre style="margin: 0 0 10px 0; padding: 10px 12px; font-family: var(--font-mono); font-size: 13px; background: var(--surface-3); border: 1px solid var(--border); border-radius: var(--radius-sm); color: var(--text); white-space: pre-wrap; word-break: break-all;">{{ usage.source_line }}</pre>
        <div style="font-size: 13.5px; color: var(--text-2); background: var(--warning-bg); border-left: 3px solid var(--warning); padding: 8px 12px; border-radius: 0 var(--radius-sm) var(--radius-sm) 0;">
          <strong>Fix Advice:</strong> {{ usage.fix_advice }}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}
</section>

<!-- TAB 3 · FIX PLAN -->
<section id="panel-fixplan" class="tab-panel" role="tabpanel" aria-labelledby="tab-fixplan">

  <div class="card">
    <h3 class="card-title">Recommended Fix Sequence</h3>
    <p class="card-sub">{% if upgrade_headline %}{{ upgrade_headline }} {% endif %}Apply these steps in order; validate each before moving on.{% if fix_plan.total_estimated_minutes %} Estimated total: {{ (fix_plan.total_estimated_minutes / 60)|round(1) }} h.{% endif %}</p>

    {% if fix_plan.steps %}
    {% for step in fix_plan.steps %}
    <div class="step-card">
      <div class="step-head">
        <span class="step-label">Step {{ step.order }} of {{ fix_plan.steps|length }}</span>
        <span class="step-time">~{{ step.estimated_minutes or 30 }} min</span>
      </div>
      <div class="step-title">Upgrade {{ step.package }} to {{ step.to_version }}</div>
      {% if step.reason %}<p class="step-reason"><strong>Why:</strong> {{ step.reason }}</p>{% endif %}
      {% if step.command %}
      <div class="cmd-block">
        <code>{{ step.command }}</code>
        <button class="btn-copy" data-copy="{{ step.command }}" type="button">Copy</button>
      </div>
      {% endif %}
      {% if step.tests_to_run %}<p class="step-tests"><strong>Test:</strong> {{ step.tests_to_run|join(', ') }}</p>{% endif %}
    </div>
    {% endfor %}
    {% else %}
    <div class="empty-state">No upgrade steps were generated. Either no CVEs need fixing or the upgrade simulator was not run.</div>
    {% endif %}
  </div>

  {% if remediation_plan and remediation_plan['items'] %}
  <div class="card">
    <h3 class="card-title">Required Code Adaptations</h3>
    <p class="card-sub">Suggested code adaptations (remediation plan generated via {% if remediation_plan.generated_by == 'gemini' %}Gemini AI{% else %}deterministic rules{% endif %}) to safely perform the upgrade.</p>
    <div style="display: flex; flex-direction: column; gap: 16px;">
      {% for item in remediation_plan['items'] %}
      <div style="border: 1px solid var(--border); border-radius: var(--radius-md); padding: 18px; background: var(--surface);">
        <div style="font-family: var(--font-mono); font-size: 13.5px; font-weight: 700; color: var(--primary-2); margin-bottom: 6px;">
          {{ item.file }}: Line {{ item.line }}
        </div>
        <p style="font-size: 14px; color: var(--text-2); margin-bottom: 12px; line-height: 1.5;">{{ item.explanation }}</p>
        
        <div class="code-diff">
          <div class="diff-old">
            <div style="font-size: 11px; text-transform: uppercase; font-weight: 700; letter-spacing: 0.05em; margin-bottom: 6px; color: var(--danger);">Before (vulnerable/deprecated usage)</div>
            <pre style="margin: 0; font-family: var(--font-mono); font-size: 12.5px; white-space: pre-wrap; word-break: break-all;">{{ item.old_code }}</pre>
          </div>
          <div class="diff-new">
            <div style="font-size: 11px; text-transform: uppercase; font-weight: 700; letter-spacing: 0.05em; margin-bottom: 6px; color: var(--success);">After (refactored/remediated code)</div>
            <pre style="margin: 0; font-family: var(--font-mono); font-size: 12.5px; white-space: pre-wrap; word-break: break-all;">{{ item.new_code }}</pre>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
  {% endif %}

  {% if mitigations %}
  <div class="card">
    <h3 class="card-title">Mitigation Suggestions</h3>
    <p class="card-sub">Defense-in-depth steps to apply alongside the upgrade.</p>
    <ul class="mitigation-list">
      {% for m in mitigations %}
      <li><span class="mit-icon">{{ m.icon }}</span><div><strong>{{ m.title }}.</strong> {{ m.body }}</div></li>
      {% endfor %}
    </ul>
  </div>
  {% endif %}
</section>

<!-- TAB 4 · PATCHES -->
<section id="panel-patches" class="tab-panel" role="tabpanel" aria-labelledby="tab-patches">

  <div class="card">
    <h3 class="card-title">Patch Diff &amp; Code Usage</h3>
    <p class="card-sub">Side-by-side view of the upstream patch and the call sites in this repo.</p>

    {% set patch_cves = cves|selectattr('patch')|list %}
    {% if patch_cves %}
    <select id="patch-select" class="patch-select" aria-label="Select CVE to inspect">
      {% for c in patch_cves %}
      <option value="{{ c.cve_id }}">{{ c.cve_id }} — {{ c.vulnerable_symbol or c.package }}</option>
      {% endfor %}
    </select>

    {% for c in patch_cves %}
    <div data-patch="{{ c.cve_id }}"{% if not loop.first %} hidden{% endif %}>
      <div style="margin-bottom:18px;">
        <div style="font-size:15.5px;font-weight:700;margin-bottom:4px;">{{ c.cve_id }} — {{ c.vulnerable_symbol or c.package }}</div>
        <div style="font-size:13px;color:var(--text-3);">
          Change type: <span class="badge badge-{{ c.change_classification or 'INTERNAL_CHANGE' }}">{{ c.change_classification or 'INTERNAL_CHANGE' }}</span>
          {% if c.patch.url %} · <a href="{{ c.patch.url }}" target="_blank" rel="noopener">Commit {{ c.patch.commit_sha or 'view' }}</a>{% endif %}
        </div>
      </div>

      <div class="diff-grid">
        <div class="diff-panel before">
          <h3>Before · vulnerable</h3>
          <pre>{{ c.patch.before_code or '# Patch source unavailable' }}</pre>
        </div>
        <div class="diff-panel after">
          <h3>After · patched</h3>
          <pre>{{ c.patch.after_code or '# Patch source unavailable' }}</pre>
        </div>
      </div>

      {% if c.references %}
      <div class="usage-section">
        <h3>Your code that calls this function</h3>
        {% for r in c.references %}
        {% set ep = r.entry_point_info or {} %}
        <div class="usage-site">
          <div class="usage-loc">{{ r.file }}:{{ r.line }}{% if ep.route %} ({{ ep.method or 'GET' }} {{ ep.route }}){% endif %}</div>
          {% if r.source or r.code_snippet %}
          <pre class="usage-code">{{ r.source or r.code_snippet }}</pre>
          {% endif %}
        </div>
        {% endfor %}
      </div>
      {% endif %}
    </div>
    {% endfor %}
    {% else %}
    <div class="empty-state">No patches cached for the CVEs in this scan. Re-run with patch fetching enabled to see diffs here.</div>
    {% endif %}
  </div>
</section>

<!-- TAB 5 · GRAPH -->
<section id="panel-graph" class="tab-panel" role="tabpanel" aria-labelledby="tab-graph">

  {% set gs = graph_stats or {} %}
  {% set gs_counts = gs.counts or {} %}
  {% set status_class = 'is-live' if gs.mode == 'neo4j' else ('is-snapshot' if gs.mode == 'snapshot' else 'is-fallback') %}
  <div class="card live-graph-card">
    <div class="live-graph-header">
      <h3 class="card-title">Live Knowledge Graph</h3>
      <span class="live-graph-status {{ status_class }}">
        <span class="live-dot"></span>
        {% if gs.mode == 'neo4j' %}Live Neo4j · {{ gs.uri or 'bolt://localhost:7687' }}
        {% elif gs.mode == 'snapshot' %}Snapshot mode (Neo4j unavailable)
        {% else %}Derived from assessment (no graph snapshot){% endif %}
      </span>
    </div>
    <p class="card-sub">Interactive force-directed view of packages, CVEs, services, and call chains. Drag nodes to reposition; click a node to highlight its blast radius; double-click empty space to reset.</p>

    <div class="graph-toolbar" role="toolbar" aria-label="Graph filters">
      <button type="button" data-graph-filter="all" class="is-active">All ({{ gs.visible_nodes or 0 }})</button>
      <button type="button" data-graph-filter="package">Packages ({{ gs_counts.packages or 0 }})</button>
      <button type="button" data-graph-filter="cve">CVEs ({{ gs_counts.cves or 0 }})</button>
      <button type="button" data-graph-filter="service">Services ({{ gs_counts.services or 0 }})</button>
      <button type="button" data-graph-filter="function">Functions ({{ gs_counts.functions or 0 }})</button>
      <button type="button" data-graph-filter="reachable">Reachable only</button>
      <button type="button" id="graph-fit" style="margin-left:auto;">⤢ Fit view</button>
      <button type="button" id="graph-reset">Reset</button>
    </div>

    <div id="neo4j-graph" class="live-graph-canvas" role="img" aria-label="Interactive security graph" tabindex="0">
      <div class="live-graph-empty" id="neo4j-graph-empty" style="display:none;">
        No graph nodes available. Run with <code>--neo4j</code> or ensure <code>graph_snapshot.json</code> contains packages and CVEs.
      </div>
    </div>

    <div class="live-graph-legend" aria-label="Graph legend">
      <span class="legend-item"><span class="swatch pkg"></span> Package</span>
      <span class="legend-item"><span class="swatch cve"></span> CVE</span>
      <span class="legend-item"><span class="swatch svc"></span> Service</span>
      <span class="legend-item"><span class="swatch fn"></span> Function</span>
    </div>
    <div class="live-graph-meta">
      <span><strong>Source:</strong> {{ gs.label or 'Derived' }}</span>
      <span><strong>Visible:</strong> {{ gs.visible_nodes or 0 }} nodes · {{ gs.visible_edges or 0 }} edges</span>
      <span><strong>Snapshot total:</strong> {{ gs.total_nodes or 0 }} nodes · {{ gs.total_edges or 0 }} edges</span>
      {% set ec = gs.edge_counts or {} %}
      {% if ec %}<span><strong>Edges:</strong>
        {% for kind, count in ec.items() if count %}{{ kind }}={{ count }}{% if not loop.last %} · {% endif %}{% endfor %}
      </span>{% endif %}
    </div>
  </div>

  <div class="card">
    <h3 class="card-title">A · Dependency Chain (DEPENDS_ON)</h3>
    <p class="card-sub">Transitive dependency tree and conflict propagation path.</p>
    <div class="graph-wrap">
      <div class="graph-caption">Upgrade target · dependency conflict trace</div>
      <div class="dep-tree">{{ dep_tree_html|safe }}</div>
    </div>
  </div>

  <div class="card">
    <h3 class="card-title">B · CVE Relationship Graph</h3>
    <p class="card-sub">Knowledge-graph pattern around the worst CVE.</p>
    <div class="cypher-block">{{ cypher_html|safe }}</div>
  </div>

  <div class="card">
    <h3 class="card-title">C · Blast Radius Visualization</h3>
    <p class="card-sub">Impact propagation: CVE → vulnerable symbols → files → services.</p>
    <div class="graph-wrap">
      {{ blast_svg_html|safe }}
      <div class="graph-legend">
        <div class="legend-row"><span class="legend-dot" style="background:var(--danger)"></span> CVE / Critical service</div>
        <div class="legend-row"><span class="legend-dot" style="background:var(--warning)"></span> Vulnerable symbol</div>
        <div class="legend-row"><span class="legend-dot" style="background:var(--info)"></span> File / call site</div>
      </div>
    </div>
  </div>
</section>

<!-- TAB 6 · AUDIT & EVIDENCE -->
<section id="panel-audit" class="tab-panel" role="tabpanel" aria-labelledby="tab-audit">

  <div class="card">
    <h3 class="card-title">Risk Scoring Formula</h3>
    <p class="card-sub">Deterministic scorer v{{ metadata.scorer_version|default('1.0.0') }} · thresholds BLOCK ≥ {{ audit.thresholds.BLOCK|default(70) }}, REVIEW ≥ {{ audit.thresholds.REVIEW|default(40) }}.</p>
    <pre class="formula-block">{{ audit.formula }}</pre>

    {% if score_breakdown.rows %}
    <table class="score-breakdown-table">
      <thead>
        <tr>
          <th>Dimension</th>
          <th>Raw Value</th>
          <th>Weight</th>
          <th>Contribution</th>
          <th>Impact</th>
        </tr>
      </thead>
      <tbody>
        {% for row in score_breakdown.rows %}
        {% set pct = ((row.contribution_pts / row.contribution_max) * 100)|round|int if row.contribution_max else 0 %}
        <tr>
          <td>{{ row.dimension }}</td>
          <td><span class="mono {% if row.color == 'danger' %}" style="color:var(--danger){% elif row.color == 'warning' %}" style="color:var(--warning){% endif %}">{{ row.raw_value }}</span></td>
          <td><span class="mono muted">{{ row.weight }}</span></td>
          <td>
            <span class="mono" style="color:var(--{{ row.color }})">{{ row.contribution_pts }} pts</span>
            <div class="contrib-bar-wrap"><div class="contrib-bar" style="width:{{ pct }}%;background:var(--{{ row.color }})"></div></div>
          </td>
          <td><span class="badge badge-{{ row.impact }}">{{ row.impact }}</span></td>
        </tr>
        {% endfor %}
        <tr class="total-row">
          <td>Total Risk Score</td>
          <td colspan="2"><span class="mono" style="color:var(--danger);font-size:17px;">{{ score_breakdown.total|fmt_num(0) }} / 100</span></td>
          <td colspan="2"><span class="badge badge-{{ score_breakdown.verdict }}">{{ score_breakdown.verdict }}</span></td>
        </tr>
      </tbody>
    </table>
    {% endif %}
  </div>

  <div class="card">
    <h3 class="card-title">Raw Evidence · Assessment Snapshot</h3>
    <p class="card-sub">Machine-readable risk assessment payload produced by the scorer.</p>
    <pre class="raw-json">{
  "scorer_version": "{{ metadata.scorer_version|default('1.0.0') }}",
  "generated_at":   "{{ metadata.generated_at|default('') }}",
  "target_repo":    "{{ metadata.target_repo|default('') }}",
  "summary": {
    "overall_recommendation": "{{ overall.recommendation }}",
    "overall_raw_risk":       {{ overall.raw_risk|fmt_num(0) }},
    "total_cves":             {{ summary_stats.total_cves|default(0) }},
    "reachable_cves":         {{ summary_stats.reachable_cves|default(0) }},
    "would_break_build":      {{ 'true' if summary_stats.would_break_build else 'false' }}
  },
  "cves": [{% for c in cves[:5] %}
    {
      "cve_id":         "{{ c.cve_id }}",
      "package":        "{{ c.package }}",
      "cvss":           {{ c.cvss|fmt_num(1) }},
      "epss":           {{ c.epss|fmt_num(3) }},
      "in_kev":         {{ 'true' if c.in_kev else 'false' }},
      "is_reachable":   {{ 'true' if c.is_reachable else 'false' }},
      "raw_risk":       {{ c.raw_risk|fmt_num(0) }},
      "recommendation": "{{ c.recommendation }}"
    }{{ '' if loop.last else ',' }}{% endfor %}{% if cves|length > 5 %},
    ... {{ cves|length - 5 }} more CVE(s) truncated{% endif %}
  ]
}</pre>
  </div>

  <div class="card">
    <h3 class="card-title">Tools, Configuration &amp; Pipeline Coverage</h3>
    <p class="card-sub">Snapshot of pipeline inputs, tools, and which outputs are surfaced in this report.</p>

    <div class="section-head">Tools used in this scan</div>
    <div class="meta-grid">
      {% for label, value in tools_metadata.items() %}
      <div class="meta-item"><span class="k">{{ label }}</span><span class="v">{{ value }}</span></div>
      {% endfor %}
    </div>

    <div class="section-head">Scan configuration</div>
    <div class="meta-grid">
      {% for label, value in scan_configuration.items() %}
      <div class="meta-item"><span class="k">{{ label }}</span><span class="v{% if label == 'Verdict' %}{% if rec == 'BLOCK' %} danger{% elif rec == 'REVIEW' %} warning{% else %} success{% endif %}{% endif %}">{{ value }}</span></div>
      {% endfor %}
    </div>

    <div class="section-head">SBOM summary</div>
    <div class="meta-grid">
      <div class="meta-item"><span class="k">Total Packages</span><span class="v">{{ sbom.total_packages|default(0) }}</span></div>
      <div class="meta-item"><span class="k">Direct Dependencies</span><span class="v">{{ sbom.direct_dependencies|default(0) }}</span></div>
      <div class="meta-item"><span class="k">Transitive Dependencies</span><span class="v">{{ sbom.transitive_dependencies|default(0) }}</span></div>
      <div class="meta-item"><span class="k">Python Packages</span><span class="v">{{ sbom.python_packages|default(0) }}</span></div>
      <div class="meta-item"><span class="k">NPM Packages</span><span class="v">{{ sbom.npm_packages|default(0) }}</span></div>
      <div class="meta-item"><span class="k">Vulnerable Packages</span><span class="v{% if sbom.vulnerable_packages|default(0) > 0 %} danger{% endif %}">{{ sbom.vulnerable_packages|default(0) }}</span></div>
      <div class="meta-item"><span class="k">KEV Listed</span><span class="v{% if sbom.kev_listed|default(0) > 0 %} danger{% endif %}">{{ sbom.kev_listed|default(0) }}</span></div>
      <div class="meta-item"><span class="k">Data Source</span><span class="v">{{ sbom.source|default('assessment_fallback') }}</span></div>
    </div>

    {% if reachability_chains %}
    <div class="section-head">Reachability call chains</div>
    <div class="meta-grid">
      {% for chain in reachability_chains %}
      <div class="meta-item"><span class="k">{{ chain.label }}</span><span class="v">{{ chain.chain }}</span></div>
      {% endfor %}
    </div>
    {% endif %}

    <div class="section-head">Pipeline output coverage</div>
    <div class="meta-grid">
      {% for item in pipeline_coverage %}
      <div class="meta-item"><span class="k">{{ item.name }}</span><span class="v {{ item.color }}">{{ item.status }}</span></div>
      {% endfor %}
    </div>
  </div>
</section>

</main>

<footer class="site-footer">
  Pre-Upgrade Risk Assessment · {{ metadata.target_repo|default('project') }} · Scan {{ metadata.generated_at|default('') }} · Verdict {{ rec }}
</footer>

<script>
(function () {
  "use strict";

  var root = document.documentElement;
  var themeBtn = document.getElementById("theme-toggle");
  var themeLabel = themeBtn ? themeBtn.querySelector(".theme-label") : null;
  var storedTheme = localStorage.getItem("risk-report-theme");
  var prefersDark = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
  var initialTheme = storedTheme || (prefersDark ? "dark" : "light");

  function applyTheme(theme) {
    root.setAttribute("data-theme", theme);
    localStorage.setItem("risk-report-theme", theme);
    if (themeLabel) themeLabel.textContent = theme === "dark" ? "Dark" : "Light";
  }
  applyTheme(initialTheme);
  if (themeBtn) {
    themeBtn.addEventListener("click", function () {
      var cur = root.getAttribute("data-theme") === "dark" ? "dark" : "light";
      applyTheme(cur === "dark" ? "light" : "dark");
    });
  }

  var TAB_IDS = ["overview", "risks", "fixplan", "patches", "graph", "audit"];
  var tabBtns = Array.prototype.slice.call(document.querySelectorAll(".tab-btn"));
  var panels = Array.prototype.slice.call(document.querySelectorAll(".tab-panel"));
  var mobileSelect = document.getElementById("tab-select-mobile");

  function activateTab(id) {
    if (TAB_IDS.indexOf(id) === -1) id = "overview";
    tabBtns.forEach(function (btn) {
      var on = btn.dataset.tab === id;
      btn.setAttribute("aria-selected", on ? "true" : "false");
    });
    panels.forEach(function (panel) {
      panel.classList.toggle("active", panel.id === "panel-" + id);
    });
    if (mobileSelect) mobileSelect.value = id;
    history.replaceState(null, "", "#" + id);
  }

  tabBtns.forEach(function (btn, i) {
    btn.addEventListener("click", function () { activateTab(btn.dataset.tab); });
    btn.addEventListener("keydown", function (e) {
      if (e.key === "ArrowRight" || e.key === "ArrowLeft") {
        e.preventDefault();
        var next = e.key === "ArrowRight" ? (i + 1) % tabBtns.length : (i - 1 + tabBtns.length) % tabBtns.length;
        tabBtns[next].focus();
        tabBtns[next].click();
      }
    });
  });
  if (mobileSelect) mobileSelect.addEventListener("change", function () { activateTab(mobileSelect.value); });
  var initialHash = location.hash.replace("#", "");
  if (TAB_IDS.indexOf(initialHash) !== -1) activateTab(initialHash);

  var searchInput = document.getElementById("findings-search");
  var verdictSelect = document.getElementById("findings-verdict");
  var reachCheck = document.getElementById("findings-reachable");
  var countEl = document.getElementById("findings-count");
  var mainRows = Array.prototype.slice.call(document.querySelectorAll("#risks-table tr.main-row"));

  function detailRowFor(mainRow) {
    var next = mainRow.nextElementSibling;
    return next && next.classList.contains("detail-row") ? next : null;
  }

  function applyFindingsFilter() {
    var q = (searchInput && searchInput.value || "").toLowerCase().trim();
    var verdict = verdictSelect ? verdictSelect.value : "all";
    var onlyReach = reachCheck ? reachCheck.checked : false;
    var visible = 0;
    mainRows.forEach(function (row) {
      var rowVerdict = row.getAttribute("data-verdict") || "";
      var reachable = row.getAttribute("data-reachable") === "1";
      var text = row.textContent.toLowerCase();
      var detail = detailRowFor(row);
      var matchQ = !q || text.indexOf(q) >= 0;
      var matchV = verdict === "all" || rowVerdict === verdict;
      var matchR = !onlyReach || reachable;
      var show = matchQ && matchV && matchR;
      row.style.display = show ? "" : "none";
      if (detail) detail.style.display = show ? "" : "none";
      if (show) visible += 1;
    });
    if (countEl) countEl.textContent = "Showing " + visible + " of " + mainRows.length;
  }
  if (searchInput) searchInput.addEventListener("input", applyFindingsFilter);
  if (verdictSelect) verdictSelect.addEventListener("change", applyFindingsFilter);
  if (reachCheck) reachCheck.addEventListener("change", applyFindingsFilter);
  applyFindingsFilter();

  mainRows.forEach(function (row) {
    row.addEventListener("click", function () {
      var detail = detailRowFor(row);
      if (!detail) return;
      var open = detail.classList.toggle("hidden") === false;
      row.classList.toggle("expanded", open);
      row.setAttribute("aria-expanded", open ? "true" : "false");
    });
    row.addEventListener("keydown", function (e) {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        row.click();
      }
    });
  });

  var patchSelect = document.getElementById("patch-select");
  var patchBlocks = Array.prototype.slice.call(document.querySelectorAll("[data-patch]"));
  function showPatch(id) {
    patchBlocks.forEach(function (b) { b.hidden = b.getAttribute("data-patch") !== id; });
  }
  if (patchSelect) {
    patchSelect.addEventListener("change", function () { showPatch(patchSelect.value); });
    showPatch(patchSelect.value);
  }

  document.addEventListener("click", function (e) {
    var btn = e.target.closest && e.target.closest(".btn-copy");
    if (!btn) return;
    var text = btn.getAttribute("data-copy") || "";
    if (!text || !navigator.clipboard || !navigator.clipboard.writeText) return;
    navigator.clipboard.writeText(text).then(function () {
      var orig = btn.textContent;
      btn.classList.add("copied");
      btn.textContent = "Copied";
      setTimeout(function () {
        btn.classList.remove("copied");
        btn.textContent = orig;
      }, 1500);
    });
  });

  /* ── Live knowledge graph (vis-network) ─────────────────────── */
  var VIS_GRAPH = {{ vis_graph_json|safe }};
  var REPORT_CVES = {{ cves_json|safe }};
  var graphContainer = document.getElementById("neo4j-graph");
  var graphEmpty = document.getElementById("neo4j-graph-empty");
  var network = null;
  var allNodes = null;
  var allEdges = null;
  var graphInitialized = false;
  var reachableCveIds = new Set(
    (REPORT_CVES || []).filter(function (c) { return c.is_reachable; })
      .map(function (c) { return (c.cve_id || "").toUpperCase(); })
  );

  function fontColor() {
    return root.getAttribute("data-theme") === "dark" ? "#e6edf8" : "#142036";
  }

  function buildNetwork() {
    if (graphInitialized) return;
    graphInitialized = true;
    var nodesIn = VIS_GRAPH.nodes || [];
    var edgesIn = VIS_GRAPH.edges || [];
    if (!nodesIn.length || typeof vis === "undefined") {
      if (graphEmpty) {
        graphEmpty.style.display = "flex";
        if (typeof vis === "undefined") {
          graphEmpty.innerHTML = "Graph library not loaded. Re-run with <code>--offline</code> to inline vis-network, or check your network connection.";
        }
      }
      graphContainer.style.height = "180px";
      return;
    }
    if (graphEmpty) graphEmpty.style.display = "none";
    var NEO_COLORS = {
      cve:      '#F25F5C',
      package:  '#4FC1E9',
      cwe:      '#FFCE54',
      function: '#AC92EC',
      service:  '#48CFAD',
    };
    allNodes = new vis.DataSet(nodesIn.map(function (n) {
      var displayLabel = n.label || '';
      var nodeSize = 25;
      var group = n.group || n.type || 'function';
      
      if (group === "cve") {
        var meta = n._meta || n;
        displayLabel = (meta.severity || "").toUpperCase() || n.cve_id || n.label || "CVE";
        nodeSize = 28;
      } else if (group === "package") {
        displayLabel = n.package || (n.label || '').split('\n')[0];
        nodeSize = 32;
      } else if (group === "service") {
        displayLabel = n.service || (n.label || '').split('\n')[0];
        nodeSize = 30;
      } else if (group === "function") {
        displayLabel = n.label || 'fn';
        nodeSize = 20;
      } else if (group === "cwe") {
        displayLabel = (n.label || '').split('\n')[0];
        nodeSize = 24;
      }
      
      var col = NEO_COLORS[group] || (n.color && n.color.background) || '#718096';
      
      return Object.assign({}, n, {
        shape: "circle",
        label: displayLabel,
        size: nodeSize,
        borderWidth: 2,
        color: {
          background: col,
          border:     col,
          highlight:  { background: col, border: "#ffffff" },
          hover:      { background: col, border: "#ffffff" }
        },
        font: { color: "#ffffff", size: 9, face: "Inter, system-ui", bold: true },
        _meta: n,
      });
    }));
    allEdges = new vis.DataSet(edgesIn.map(function (e) {
      return Object.assign({}, e, {
        color: { color: 'rgba(255,255,255,0.18)', highlight: 'rgba(255,255,255,0.7)', hover: 'rgba(255,255,255,0.45)' },
        font: {
          size: 8, align: "middle",
          color: "rgba(255,255,255,0.45)",
          strokeWidth: 0,
        },
      });
    }));
    network = new vis.Network(graphContainer, { nodes: allNodes, edges: allEdges }, {
      physics: {
        enabled: true,
        barnesHut: {
          gravitationalConstant: -10000,
          springLength: 140,
          springConstant: 0.04,
          damping: 0.15,
        },
        stabilization: { iterations: 220, fit: true },
      },
      interaction: { hover: true, tooltipDelay: 120, navigationButtons: false, keyboard: true },
      layout: { improvedLayout: true },
      nodes: { borderWidth: 2, shadow: { enabled: true, size: 4, x: 0, y: 1 } },
      edges: { smooth: { type: "continuous" }, selectionWidth: 1.5 },
    });
    network.once("stabilizationIterationsDone", function () {
      network.setOptions({ physics: { enabled: false } });
    });
    network.on("click", function (params) {
      if (params.nodes && params.nodes.length) {
        highlightNeighborhood(params.nodes[0]);
      } else {
        resetHighlight();
      }
    });
    network.on("doubleClick", function () { resetHighlight(); });
    var fitBtn = document.getElementById("graph-fit");
    if (fitBtn) fitBtn.addEventListener("click", function () { network.fit({ animation: true }); });
    var resetBtn = document.getElementById("graph-reset");
    if (resetBtn) resetBtn.addEventListener("click", function () {
      applyFilter("all"); resetHighlight(); network.fit({ animation: true });
    });
  }

  function highlightNeighborhood(nodeId) {
    if (!allNodes || !allEdges) return;
    var keep = new Set([nodeId]);
    var changed = true;
    while (changed) {
      changed = false;
      allEdges.forEach(function (e) {
        if (keep.has(e.from) && !keep.has(e.to)) { keep.add(e.to); changed = true; }
        if (keep.has(e.to) && !keep.has(e.from)) { keep.add(e.from); changed = true; }
      });
    }
    allNodes.forEach(function (n) {
      allNodes.update({ id: n.id, opacity: keep.has(n.id) ? 1 : 0.18 });
    });
    allEdges.forEach(function (e) {
      var on = keep.has(e.from) && keep.has(e.to);
      allEdges.update({ id: e.id, color: { opacity: on ? 1 : 0.08 } });
    });
  }

  function resetHighlight() {
    if (!allNodes || !allEdges) return;
    allNodes.forEach(function (n) { allNodes.update({ id: n.id, opacity: 1 }); });
    allEdges.forEach(function (e) {
      allEdges.update({ id: e.id, color: Object.assign({}, e.color || {}, { opacity: 1 }) });
    });
  }

  function applyFilter(filter) {
    if (!allNodes || !allEdges) return;
    Array.prototype.forEach.call(document.querySelectorAll("[data-graph-filter]"), function (btn) {
      btn.classList.toggle("is-active", btn.getAttribute("data-graph-filter") === filter);
    });
    allNodes.forEach(function (n) {
      var meta = n._meta || {};
      var show = true;
      if (filter === "all") show = true;
      else if (filter === "reachable") {
        if (meta.group === "cve") {
          show = reachableCveIds.has((meta.cve_id || "").toUpperCase());
        } else {
          show = true;
        }
      } else {
        show = meta.group === filter;
      }
      allNodes.update({ id: n.id, hidden: !show });
    });
    // Hide edges touching hidden nodes.
    var visibleIds = new Set();
    allNodes.forEach(function (n) { if (!n.hidden) visibleIds.add(n.id); });
    allEdges.forEach(function (e) {
      var on = visibleIds.has(e.from) && visibleIds.has(e.to);
      allEdges.update({ id: e.id, hidden: !on });
    });
  }

  Array.prototype.forEach.call(document.querySelectorAll("[data-graph-filter]"), function (btn) {
    btn.addEventListener("click", function () {
      applyFilter(btn.getAttribute("data-graph-filter"));
    });
  });

  function refreshGraphFonts() {
    if (!allNodes) return;
    var color = fontColor();
    allNodes.forEach(function (n) {
      allNodes.update({ id: n.id, font: { color: color, size: 14, multi: true, face: "Inter, system-ui" } });
    });
  }

  // Lazy-init graph when the Graph tab is opened so vis-network has a sized container.
  var graphTabBtn = document.querySelector('[data-tab="graph"]');
  if (graphTabBtn) {
    graphTabBtn.addEventListener("click", function () {
      setTimeout(function () {
        buildNetwork();
        if (network) network.redraw();
      }, 0);
    });
  }
  // If the report deep-links straight to #graph, init right away.
  if ((location.hash || "").indexOf("graph") !== -1) {
    setTimeout(buildNetwork, 0);
  }
  // Re-tint node labels when the user flips the theme.
  if (themeBtn) themeBtn.addEventListener("click", function () { setTimeout(refreshGraphFonts, 0); });
})();
</script>
</body>
</html>
